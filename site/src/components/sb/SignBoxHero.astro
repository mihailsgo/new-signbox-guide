---
/**
 * SignBoxHero.astro - cinematic hero animation for the SignBox guide.
 *
 * A 1:1 port of the design handoff reference build
 * (`signbox-hero-reference.html`): a dark "stage" telling the 5-step signing
 * story on a loop - Upload -> Workflow -> Recipients -> Sign -> Signed.
 *
 * All motion is plain CSS transitions/keyframes driven by a single integer
 * `step` (0..4) in the <script> below. Tokens, colors, timing and easing match
 * the handoff README exactly.
 *
 * Notes on the port:
 *  - Keyframes live in a `<style is:global>` block so the inline
 *    `style="animation:sbX ..."` references in the markup resolve (Astro would
 *    otherwise scope/rename keyframe names declared in a scoped block).
 *  - The handoff's placeholder pravatar photos are replaced with self-contained
 *    inline-SVG avatars (no network dependency, CSP/offline safe). Swap these
 *    for real headshots when assets are available.
 */

// Inline-SVG avatars (replace the handoff's i.pravatar.cc placeholders).
// Signers (Legal, Finance) read blue; the Approver (Director) reads violet.
const avLegal = `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" aria-hidden="true">
  <circle cx="16" cy="16" r="16" fill="#3D7BFF" fill-opacity="0.22"/>
  <circle cx="16" cy="13" r="5.5" fill="#fbc3a6"/>
  <path d="M10 13c0-3.5 2.5-6 6-6s6 2.5 6 6c0 .5-.2 1-.5 1.5C21 12 20 11 19 11c-1 0-1.5.8-2 1.5-.5.7-1 .5-2 0s-1.5-1.5-2-1.5c-1 0-2 1-2.5 3-.5-.5-.5-1-.5-1z" fill="#4a3728"/>
  <path d="M6 27c0-4 4-6 10-6s10 2 10 6" fill="#1e3a6b"/>
  <path d="M13 21l3 4 3-4" fill="#6AA1FF"/>
</svg>`;

const avFinance = `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" aria-hidden="true">
  <circle cx="16" cy="16" r="16" fill="#3D7BFF" fill-opacity="0.22"/>
  <circle cx="16" cy="13" r="5.2" fill="#fcd3ab"/>
  <path d="M10 13c0-4 3-6.5 6-6.5s6 2.5 6 6.5v5c0 1-1.5 1-2.5 0v-3.5c-1 0-1.5-1-1.5-1h-4s-.5 1-1.5 1v3.5c-1 1-2.5 1-2.5 0z" fill="#8a5a2b"/>
  <path d="M6 27c0-4 4-6 10-6s10 2 10 6" fill="#1e3a6b"/>
  <path d="M13 21l3 3 3-3" fill="#6AA1FF"/>
</svg>`;

const avDirector = `<svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%" aria-hidden="true">
  <circle cx="16" cy="16" r="16" fill="#8B6BFF" fill-opacity="0.24"/>
  <circle cx="16" cy="13" r="5.5" fill="#e0a98c"/>
  <path d="M9.5 13c0-3.5 2.5-6 6.5-6s6.5 2.5 6.5 6c0 1-.5 1.5-1.5 1.5C20 12 19.5 11 18.5 11c-1 0-1 1-2.5 1s-1.5-1-2.5-1c-1 0-1.5 1-2 1.5-.5-.5-1-1-1-1.5z" fill="#4b3a6b"/>
  <path d="M6 27c0-4 4-6 10-6s10 2 10 6" fill="#3b2a6b"/>
  <path d="M13 21l3 4 3-4" fill="#B49BFF"/>
</svg>`;
---

<div class="sbh">
  <!-- ambient -->
  <div class="amb amb-glow"></div>
  <div class="amb amb-grid"></div>
  <div class="amb amb-sweep"></div>
  <div class="amb amb-particles">
    <span style="left:14%; top:30%; width:4px; height:4px; background:#6AA1FF; animation:sbTwinkle 4s ease-in-out infinite;"></span>
    <span style="left:78%; top:22%; width:3px; height:3px; background:#9bd9b8; animation:sbTwinkle 5.5s ease-in-out infinite .6s;"></span>
    <span style="left:62%; top:64%; width:5px; height:5px; background:#6AA1FF; animation:sbDrift 9s linear infinite alternate;"></span>
    <span style="left:30%; top:74%; width:3px; height:3px; background:#cbd9ff; animation:sbTwinkle 6s ease-in-out infinite 1.2s;"></span>
    <span style="left:88%; top:54%; width:4px; height:4px; background:#7fe0ad; animation:sbDrift 11s linear infinite alternate;"></span>
    <span style="left:8%; top:60%; width:3px; height:3px; background:#6AA1FF; animation:sbTwinkle 5s ease-in-out infinite .3s;"></span>
  </div>

  <!-- header -->
  <div class="hdr">
    <div>
      <div class="kicker">TrustLynx SignBox</div>
      <h2 class="title">Secure electronic signing, end&#8209;to&#8209;end</h2>
    </div>
    <div class="hdr-right">
      <div class="steppill">Step <b id="stepN">1</b> of 5 <span class="sp-sep">·</span><span id="stepTitle">Upload document</span></div>
      <div class="hbar"><div id="headerFill"></div></div>
      <button id="playBtn" type="button">Pause</button>
    </div>
  </div>

  <!-- rail -->
  <div class="rail"><div class="rail-inner">
    <div class="rail-track"></div>
    <div id="railFill"></div>
    <div id="travelDoc">
      <div style="position:relative; width:34px; height:42px; border-radius:7px; background:linear-gradient(160deg,#ffffff,#dbe6ff); box-shadow:0 12px 24px rgba(61,123,255,.5), 0 0 0 1px rgba(255,255,255,.5); animation:sbFloat 3s ease-in-out infinite;">
        <span style="position:absolute; top:7px; left:6px; right:6px; height:2px; background:#9bb4e8; border-radius:2px;"></span>
        <span style="position:absolute; top:13px; left:6px; right:10px; height:2px; background:#bcccf0; border-radius:2px;"></span>
        <span style="position:absolute; top:19px; left:6px; right:8px; height:2px; background:#bcccf0; border-radius:2px;"></span>
        <span style="position:absolute; bottom:5px; right:5px; width:14px; height:9px; border-radius:3px; background:#3D7BFF; color:#fff; font-size:6px; font-weight:800; display:flex; align-items:center; justify-content:center; letter-spacing:.3px;">PDF</span>
      </div>
    </div>
    <div class="orb"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4"/><path d="M8 8l4-4 4 4"/><path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg></div>
    <div class="olabel">Upload</div>
    <div class="orb"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2.3"/><circle cx="5" cy="18" r="2.3"/><circle cx="19" cy="12" r="2.3"/><path d="M7.2 7 16.8 11M7.2 17 16.8 13"/></svg></div>
    <div class="olabel">Workflow</div>
    <div class="orb"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><path d="M16 5.5a3 3 0 0 1 0 5.8"/><path d="M16.5 13.2A5.5 5.5 0 0 1 20.5 19"/></svg></div>
    <div class="olabel">Recipients</div>
    <div class="orb"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></div>
    <div class="olabel">Sign</div>
    <div class="orb"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="6.5"/><path d="M9 10l2 2 4-4"/><path d="M8.5 15.5 7 21l5-2L17 21l-1.5-5.5"/></svg></div>
    <div class="olabel">Signed</div>
  </div></div>

  <!-- stage -->
  <div class="stage">
    <div class="parallax" id="parallax"><div class="stage-glow"></div></div>

    <!-- Scene 0: Upload -->
    <div class="scene">
      <div style="width:300px; padding:26px; border-radius:18px; background:linear-gradient(160deg, rgba(255,255,255,.08), rgba(255,255,255,.02)); border:1.5px dashed rgba(120,160,255,.4); box-shadow:0 24px 50px -20px rgba(61,123,255,.6), inset 0 1px 0 rgba(255,255,255,.08); text-align:center;">
        <div style="position:relative; width:74px; height:90px; margin:0 auto 16px; border-radius:10px; background:linear-gradient(160deg,#ffffff,#d9e6ff); box-shadow:0 16px 30px rgba(61,123,255,.4); animation:sbFloat 3.4s ease-in-out infinite;">
          <span style="position:absolute; top:0; right:0; border-width:0 16px 16px 0; border-style:solid; border-color:transparent #b9ccf2 transparent transparent;"></span>
          <span style="position:absolute; top:18px; left:12px; right:12px; height:3px; background:#a7bdec; border-radius:2px;"></span>
          <span style="position:absolute; top:27px; left:12px; right:20px; height:3px; background:#c5d4f3; border-radius:2px;"></span>
          <span style="position:absolute; bottom:9px; left:50%; transform:translateX(-50%); font-size:11px; font-weight:800; color:#3D7BFF; letter-spacing:.5px;">PDF</span>
        </div>
        <div style="color:#eaf0ff; font-family:'Space Grotesk',sans-serif; font-size:16px; font-weight:600;">Agreement.pdf <span style="color:#7e8db0; font-weight:500;">· 248 KB</span></div>
        <div style="margin-top:14px; height:7px; border-radius:99px; background:rgba(255,255,255,.1); overflow:hidden;"><div style="height:100%; border-radius:99px; background:linear-gradient(90deg,#3D7BFF,#6AA1FF); box-shadow:0 0 12px rgba(61,123,255,.7); animation:sbProg 2.6s cubic-bezier(.4,0,.2,1) infinite;"></div></div>
        <div style="margin-top:12px; font-size:12px; color:#8da0c8;">Drop a PDF or Word file to begin</div>
      </div>
    </div>

    <!-- Scene 1: Workflow -->
    <div class="scene">
      <div style="display:flex; align-items:center; gap:0; width:100%; max-width:500px;">
        <div style="display:flex; flex-direction:column; align-items:center; gap:9px; flex:none; width:84px;">
          <div style="position:relative; width:54px; height:66px; border-radius:9px; background:linear-gradient(160deg,#fff,#dbe6ff); box-shadow:0 12px 24px rgba(61,123,255,.4);">
            <span style="position:absolute; top:0; right:0; border-width:0 12px 12px 0; border-style:solid; border-color:transparent #b9ccf2 transparent transparent;"></span>
            <span style="position:absolute; top:13px; left:9px; right:9px; height:3px; background:#a7bdec; border-radius:2px;"></span>
            <span style="position:absolute; top:21px; left:9px; right:15px; height:3px; background:#c5d4f3; border-radius:2px;"></span>
            <span style="position:absolute; bottom:7px; left:50%; transform:translateX(-50%); font-size:8px; font-weight:800; color:#3D7BFF; letter-spacing:.4px;">PDF</span>
          </div>
          <span style="font-size:10.5px; font-weight:700; color:#8da0c8; letter-spacing:.3px;">Document</span>
        </div>
        <div style="flex:1; height:3px; margin:0 4px; margin-bottom:26px; background:repeating-linear-gradient(90deg,#6AA1FF 0 7px, transparent 7px 14px); background-size:14px 3px; animation:sbFlow .8s linear infinite; border-radius:2px;"></div>
        <div style="display:flex; flex-direction:column; align-items:center; gap:9px; flex:none;">
          <div style="position:relative; width:94px; height:94px; border-radius:22px; background:linear-gradient(150deg,#3D7BFF,#2a5fd6); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:3px; box-shadow:0 0 0 6px rgba(61,123,255,.14), 0 22px 44px rgba(61,123,255,.55); animation:sbFloat 4s ease-in-out infinite;">
            <div style="position:absolute; inset:-3px; border-radius:24px; border:1px dashed rgba(255,255,255,.3); animation:sbSpin 18s linear infinite;"></div>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2.3"/><circle cx="5" cy="18" r="2.3"/><circle cx="19" cy="12" r="2.3"/><path d="M7.2 7 16.8 11M7.2 17 16.8 13"/></svg>
            <span style="font-size:10px; font-weight:800; color:#fff; letter-spacing:.5px;">SignBox</span>
          </div>
          <span style="font-size:10.5px; font-weight:700; color:#bcd0ff; letter-spacing:.3px;">Sets routing + profile</span>
        </div>
        <div style="flex:1; height:3px; margin:0 4px; margin-bottom:26px; background:repeating-linear-gradient(90deg,#6AA1FF 0 7px, transparent 7px 14px); background-size:14px 3px; animation:sbFlow .8s linear infinite; border-radius:2px;"></div>
        <div style="display:flex; flex-direction:column; align-items:center; gap:9px; flex:none; width:140px;">
          <div style="display:flex; flex-direction:column; gap:6px; width:140px;">
            <div style="display:flex; align-items:center; gap:7px; background:rgba(255,255,255,.07); border:1px solid rgba(140,165,225,.18); border-radius:9px; padding:4px 7px 4px 4px;">
              <span style="width:24px; height:24px; border-radius:50%; overflow:hidden; flex:none; border:1.5px solid rgba(120,160,255,.6); display:block;" set:html={avLegal}></span>
              <span style="font-size:11px; font-weight:600; color:#dfe7fb;">Legal</span>
              <span style="margin-left:auto; width:18px; height:18px; border-radius:50%; background:linear-gradient(150deg,#3D7BFF,#6AA1FF); color:#fff; font-size:10px; font-weight:800; display:flex; align-items:center; justify-content:center;">1</span>
            </div>
            <div style="display:flex; align-items:center; gap:7px; background:rgba(255,255,255,.07); border:1px solid rgba(140,165,225,.18); border-radius:9px; padding:4px 7px 4px 4px;">
              <span style="width:24px; height:24px; border-radius:50%; overflow:hidden; flex:none; border:1.5px solid rgba(120,160,255,.6); display:block;" set:html={avFinance}></span>
              <span style="font-size:11px; font-weight:600; color:#dfe7fb;">Finance</span>
              <span style="margin-left:auto; width:18px; height:18px; border-radius:50%; background:linear-gradient(150deg,#3D7BFF,#6AA1FF); color:#fff; font-size:10px; font-weight:800; display:flex; align-items:center; justify-content:center;">2</span>
            </div>
            <div style="display:flex; align-items:center; gap:7px; background:rgba(255,255,255,.07); border:1px solid rgba(170,150,255,.22); border-radius:9px; padding:4px 7px 4px 4px;">
              <span style="width:24px; height:24px; border-radius:50%; overflow:hidden; flex:none; border:1.5px solid rgba(170,150,255,.6); display:block;" set:html={avDirector}></span>
              <span style="font-size:11px; font-weight:600; color:#dfe7fb;">Director</span>
              <span style="margin-left:auto; width:18px; height:18px; border-radius:50%; background:linear-gradient(150deg,#8B6BFF,#b49bff); color:#fff; font-size:10px; font-weight:800; display:flex; align-items:center; justify-content:center;">3</span>
            </div>
          </div>
          <span style="font-size:10.5px; font-weight:700; color:#8da0c8; letter-spacing:.3px;">Recipients</span>
        </div>
      </div>
    </div>

    <!-- Scene 2: Recipients -->
    <div class="scene">
      <div style="display:flex; gap:14px;">
        <div style="width:130px; padding:18px 14px; border-radius:16px; background:linear-gradient(160deg,rgba(255,255,255,.09),rgba(255,255,255,.03)); border:1px solid rgba(140,165,225,.18); box-shadow:0 16px 32px -16px rgba(0,0,0,.6); text-align:center; animation:sbFloat 4s ease-in-out infinite;">
          <div style="position:relative;width:54px;height:54px;margin:0 auto 12px;"><span style="width:54px;height:54px;border-radius:50%;overflow:hidden;display:block;border:2px solid rgba(120,160,255,.65);box-shadow:0 10px 20px rgba(61,123,255,.45);" set:html={avLegal}></span><span style="position:absolute;right:1px;bottom:1px;width:13px;height:13px;border-radius:50%;background:#2DD27E;border:2px solid #0c1326;box-shadow:0 0 8px rgba(45,210,126,.85);"></span></div>
          <div style="color:#eaf0ff;font-size:14px;font-weight:700;">Legal</div>
          <div style="margin-top:8px;font-size:10.5px;font-weight:700;color:#bcd0ff;background:rgba(61,123,255,.18);border:1px solid rgba(120,160,255,.3);padding:3px 8px;border-radius:6px;display:inline-block;">Signer · must sign</div>
        </div>
        <div style="width:130px; padding:18px 14px; border-radius:16px; background:linear-gradient(160deg,rgba(255,255,255,.09),rgba(255,255,255,.03)); border:1px solid rgba(140,165,225,.18); box-shadow:0 16px 32px -16px rgba(0,0,0,.6); text-align:center; animation:sbFloat 4s ease-in-out infinite .5s;">
          <div style="position:relative;width:54px;height:54px;margin:0 auto 12px;"><span style="width:54px;height:54px;border-radius:50%;overflow:hidden;display:block;border:2px solid rgba(120,160,255,.65);box-shadow:0 10px 20px rgba(61,123,255,.45);" set:html={avFinance}></span><span style="position:absolute;right:1px;bottom:1px;width:13px;height:13px;border-radius:50%;background:#2DD27E;border:2px solid #0c1326;box-shadow:0 0 8px rgba(45,210,126,.85);"></span></div>
          <div style="color:#eaf0ff;font-size:14px;font-weight:700;">Finance</div>
          <div style="margin-top:8px;font-size:10.5px;font-weight:700;color:#bcd0ff;background:rgba(61,123,255,.18);border:1px solid rgba(120,160,255,.3);padding:3px 8px;border-radius:6px;display:inline-block;">Signer · must sign</div>
        </div>
        <div style="width:130px; padding:18px 14px; border-radius:16px; background:linear-gradient(160deg,rgba(255,255,255,.09),rgba(255,255,255,.03)); border:1px solid rgba(140,165,225,.18); box-shadow:0 16px 32px -16px rgba(0,0,0,.6); text-align:center; animation:sbFloat 4s ease-in-out infinite 1s;">
          <div style="position:relative;width:54px;height:54px;margin:0 auto 12px;"><span style="width:54px;height:54px;border-radius:50%;overflow:hidden;display:block;border:2px solid rgba(170,150,255,.7);box-shadow:0 10px 20px rgba(139,107,255,.45);" set:html={avDirector}></span><span style="position:absolute;right:1px;bottom:1px;width:13px;height:13px;border-radius:50%;background:#8B6BFF;border:2px solid #0c1326;box-shadow:0 0 8px rgba(139,107,255,.85);"></span></div>
          <div style="color:#eaf0ff;font-size:14px;font-weight:700;">Director</div>
          <div style="margin-top:8px;font-size:10.5px;font-weight:700;color:#d6ccff;background:rgba(139,107,255,.18);border:1px solid rgba(170,150,255,.3);padding:3px 8px;border-radius:6px;display:inline-block;">Approver · approves</div>
        </div>
      </div>
    </div>

    <!-- Scene 3: Signing -->
    <div class="scene">
      <div style="position:relative; width:172px; height:340px; border-radius:30px; background:linear-gradient(165deg,#161d33,#0e1426); border:1px solid rgba(150,175,235,.22); box-shadow:0 30px 60px -20px rgba(0,0,0,.8), inset 0 1px 0 rgba(255,255,255,.08); padding:18px 16px; animation:sbFloat 4.5s ease-in-out infinite;">
        <div style="position:absolute; inset:-30px; border-radius:50px; background:radial-gradient(circle, rgba(139,107,255,.25), transparent 70%); z-index:-1;"></div>
        <div style="width:46px; height:5px; border-radius:99px; background:rgba(255,255,255,.18); margin:0 auto 18px;"></div>
        <div style="display:flex; align-items:center; gap:8px; justify-content:center; margin-bottom:18px;">
          <div style="width:24px;height:24px;border-radius:7px;background:linear-gradient(150deg,#8B6BFF,#b49bff);display:flex;align-items:center;justify-content:center;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2" stroke-linecap="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V8a4 4 0 0 1 8 0v3"/></svg></div>
          <span style="color:#eaf0ff; font-size:13px; font-weight:700; font-family:'Space Grotesk',sans-serif;">Smart-ID</span>
        </div>
        <div style="font-size:11px; color:#8da0c8; text-align:center; margin-bottom:10px;">Enter PIN2 to sign</div>
        <div style="display:flex; gap:9px; justify-content:center; margin-bottom:22px;">
          <span style="width:13px;height:13px;border-radius:50%;background:#8B6BFF;box-shadow:0 0 10px rgba(139,107,255,.8);"></span>
          <span style="width:13px;height:13px;border-radius:50%;background:#8B6BFF;box-shadow:0 0 10px rgba(139,107,255,.8);"></span>
          <span style="width:13px;height:13px;border-radius:50%;background:#8B6BFF;box-shadow:0 0 10px rgba(139,107,255,.8);"></span>
          <span style="width:13px;height:13px;border-radius:50%;background:#8B6BFF;box-shadow:0 0 10px rgba(139,107,255,.8);"></span>
        </div>
        <div style="margin-top:6px; padding:14px; border-radius:14px; background:rgba(45,210,126,.12); border:1px solid rgba(45,210,126,.35); text-align:center;">
          <div style="width:42px;height:42px;border-radius:50%;margin:0 auto 8px;background:linear-gradient(150deg,#2DD27E,#23b76d);display:flex;align-items:center;justify-content:center;box-shadow:0 0 18px rgba(45,210,126,.7); animation:sbPulse 2.2s ease-out infinite;"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></div>
          <div style="color:#8ff0bd; font-size:13px; font-weight:700;">Signature applied</div>
        </div>
      </div>
    </div>

    <!-- Scene 4: Signed -->
    <div class="scene">
      <div style="display:flex; align-items:center; gap:30px;">
        <div style="display:flex; flex-direction:column; gap:8px;">
          <div style="display:flex; align-items:center; gap:9px; width:170px; padding:9px 12px; border-radius:11px; background:linear-gradient(160deg,rgba(255,255,255,.1),rgba(255,255,255,.03)); border:1px solid rgba(140,165,225,.2); transform:translateX(0);"><span style="width:7px;height:7px;border-radius:2px;background:#6AA1FF;"></span><span style="color:#dfe7fb;font-size:12px;font-weight:600;">Original document</span><span style="margin-left:auto;color:#7fe0ad;display:flex;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></span></div>
