<style is:global>
  /* SignBoxHero ambient keyframes - kept global so the inline
     `style="animation:sbX ..."` references in the markup resolve (Astro scopes
     keyframe names declared in a scoped <style> block, which would break them). */
  @keyframes sbFloat   { 0%,100%{ transform: translateY(0) }  50%{ transform: translateY(-9px) } }
  @keyframes sbPulse   { 0%,100%{ box-shadow: 0 0 0 0 rgba(61,123,255,.5) } 70%,100%{ box-shadow: 0 0 0 16px rgba(61,123,255,0) } }
  @keyframes sbSweep   { 0%{ transform: translateX(-130%) skewX(-18deg) } 100%{ transform: translateX(360%) skewX(-18deg) } }
  @keyframes sbFlow    { to { background-position: 14px 0 } }
  @keyframes sbProg    { 0%{ width: 6% } 55%{ width: 88% } 100%{ width: 88% } }
  @keyframes sbTwinkle { 0%,100%{ opacity:.15; transform: scale(.6) } 50%{ opacity:.9; transform: scale(1.15) } }
  @keyframes sbDrift   { 0%{ transform: translate(0,0) } 100%{ transform: translate(26px,-30px) } }
  @keyframes sbSpin    { to { transform: rotate(360deg) } }
</style>

<style>
  /* ---- shell ---- */
  .sbh {
    position: relative; width: 100%; max-width: 880px; margin: 0 auto;
    border-radius: 22px; overflow: hidden; padding: 24px 28px 30px;
    background: linear-gradient(165deg,#0c1326 0%,#0a0f1f 55%,#0b1024 100%);
    border: 1px solid rgba(120,150,220,.14);
    box-shadow: 0 30px 70px -30px rgba(10,16,36,.8), inset 0 1px 0 rgba(255,255,255,.05);
    color: #eaf0ff;
    font-family: 'Manrope', system-ui, sans-serif;
  }
  .sbh * { box-sizing: border-box; }

  /* ---- ambient layers ---- */
  .sbh .amb { position: absolute; inset: 0; pointer-events: none; }
  .sbh .amb-glow { background:
      radial-gradient(620px 320px at 30% -10%, rgba(61,123,255,.22), transparent 60%),
      radial-gradient(520px 320px at 95% 110%, rgba(45,210,126,.16), transparent 60%); }
  .sbh .amb-grid { opacity:.5; background-image:
      linear-gradient(rgba(140,165,225,.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(140,165,225,.05) 1px, transparent 1px);
      background-size: 34px 34px; }
  .sbh .amb-sweep { top:0; left:0; width:120px; height:100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.06), transparent);
      animation: sbSweep 7s ease-in-out infinite; }
  .sbh .amb-particles span { position: absolute; border-radius: 50%; }

  /* ---- header ---- */
  .sbh .hdr { position: relative; z-index: 2; display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; margin-bottom: 16px; }
  .sbh .kicker { font-size: 11px; font-weight: 800; letter-spacing: 1.4px; text-transform: uppercase; color: #bcd0ff; }
  .sbh .title { margin: 8px 0 0; font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -.3px; color: #eaf0ff; }
  .sbh .hdr-right { display: flex; flex-direction: column; align-items: flex-end; gap: 8px; }
  .sbh .steppill { font-size: 12.5px; font-weight: 700; color: #cfdcff; white-space: nowrap; }
  .sbh .steppill b { font-family: 'Space Grotesk', sans-serif; color: #6AA1FF; }
  .sbh .sp-sep { color: #5d6b8c; margin: 0 4px; }
  .sbh .hbar { width: 180px; height: 5px; border-radius: 99px; background: rgba(255,255,255,.1); overflow: hidden; }
  .sbh #headerFill { height: 100%; border-radius: 99px; }
  .sbh #playBtn { cursor: pointer; border: 1px solid rgba(150,175,235,.3); background: rgba(255,255,255,.06); color: #cfdcff; font-family: 'Manrope', sans-serif; font-weight: 700; font-size: 12px; padding: 7px 14px; border-radius: 99px; }

  /* ---- rail ---- */
  .sbh .rail { position: relative; z-index: 2; height: 150px; }
  .sbh .rail-inner { position: relative; margin: 0 44px; height: 150px; }
  .sbh .rail-track { position: absolute; top: 86px; left: 0; right: 0; height: 4px; transform: translateY(-50%); background: rgba(255,255,255,.07); border-radius: 99px; }
  .sbh #railFill { position: absolute; top: 86px; left: 0; height: 4px; transform: translateY(-50%); border-radius: 99px; box-shadow: 0 0 14px rgba(61,123,255,.6); width: 0; }
  .sbh #travelDoc { position: absolute; top: 30px; transform: translateX(-50%); z-index: 4; left: 0; }
  .sbh .orb { position: absolute; top: 86px; width: 52px; height: 52px; border-radius: 16px; display: flex; align-items: center; justify-content: center; z-index: 2; }
  .sbh .olabel { position: absolute; top: 124px; white-space: nowrap; font-size: 12px; letter-spacing: .2px; }

  /* ---- stage ---- */
  .sbh .stage { position: relative; z-index: 2; height: 430px; margin-top: 8px; border-radius: 16px; overflow: hidden;
    background: linear-gradient(160deg, rgba(255,255,255,.04), rgba(255,255,255,.01));
    border: 1px solid rgba(140,165,225,.12); }
  .sbh .parallax { position: absolute; inset: 0; }
  .sbh .stage-glow { position: absolute; left: 50%; top: 50%; width: 340px; height: 340px; transform: translate(-50%,-50%);
    background: radial-gradient(circle, rgba(61,123,255,.18), transparent 70%); pointer-events: none; }
  .sbh .scene { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; padding: 24px; }

  /* ---- responsive (fluid; keep rail/stage proportions) ---- */
  @media (max-width: 680px) {
    .sbh { padding: 18px 16px 22px; border-radius: 18px; }
    .sbh .hdr { flex-direction: column; align-items: flex-start; gap: 12px; }
    .sbh .hdr-right { align-items: flex-start; width: 100%; }
    .sbh .hbar { width: 100%; }
    .sbh .title { font-size: 19px; }
    .sbh .rail-inner { margin: 0 26px; }
    .sbh .stage { height: 390px; }
  }
</style>

<script>
  /* SignBox hero - animation driver (1:1 with the handoff reference).
     One integer `step` (0..4) drives everything. */
  let sbhActiveTimer: ReturnType<typeof setInterval> | null = null;

  function initSignBoxHero() {
    const root = document.querySelector<HTMLElement>('.sbh');
    if (!root) return;
    if (root.dataset.sbhReady === 'true') return;
    root.dataset.sbhReady = 'true';

    // ---- CONFIG (the design's tweakable props) ----
    const ACCENT = 'Signal blue';   // 'Signal blue' | 'Royal violet' | 'Emerald'
    const PACE = 'Standard';        // 'Calm' | 'Standard' | 'Snappy'

    const EASE = 'cubic-bezier(.22,1,.36,1)';
    const SPRING = 'cubic-bezier(.34,1.5,.5,1)';
    const ACCENTS: Record<string, { c1: string; c2: string; glow: string }> = {
      'Signal blue':  { c1: '#3D7BFF', c2: '#6AA1FF', glow: '61,123,255' },
      'Royal violet': { c1: '#8B6BFF', c2: '#B49BFF', glow: '139,107,255' },
      'Emerald':      { c1: '#16C784', c2: '#4BE0A8', glow: '22,199,132' },
    };
    const PACE_MS: Record<string, number> = { Calm: 3400, Standard: 2600, Snappy: 1800 };
    const STEPS = [
      { title: 'Upload document' },
      { title: 'SignBox Workflow' },
      { title: 'Recipients & Roles' },
      { title: 'National e-ID' },
      { title: 'Signed document' },
    ];
    const A = ACCENTS[ACCENT] || ACCENTS['Signal blue'];
    const N = 5;

    const orbs = Array.from(root.querySelectorAll<HTMLElement>('.orb'));
    const labels = Array.from(root.querySelectorAll<HTMLElement>('.olabel'));
    const scenes = Array.from(root.querySelectorAll<HTMLElement>('.scene'));
    const railFill = root.querySelector<HTMLElement>('#railFill')!;
    const travelDoc = root.querySelector<HTMLElement>('#travelDoc')!;
    const parallax = root.querySelector<HTMLElement>('#parallax')!;
    const seal = root.querySelector<HTMLElement>('#seal')!;
    const sigPath = root.querySelector<SVGPathElement>('#sigPath')!;
    const elStepN = root.querySelector<HTMLElement>('#stepN')!;
    const elStepTitle = root.querySelector<HTMLElement>('#stepTitle')!;
    const headerFill = root.querySelector<HTMLElement>('#headerFill')!;
    const playBtn = root.querySelector<HTMLButtonElement>('#playBtn')!;

    let step = 0;
    let playing = true;
    const pct = (v: number) => v + '%';
    const at = (i: number) => pct((i / (N - 1)) * 100);

    function render() {
      const p = pct((step / (N - 1)) * 100);

      elStepN.textContent = String(step + 1);
      elStepTitle.textContent = STEPS[step].title;
      headerFill.style.transition = 'width .6s ' + EASE;
      headerFill.style.background = 'linear-gradient(90deg,' + A.c1 + ',' + A.c2 + ')';
      headerFill.style.width = p;

      railFill.style.transition = 'width .8s ' + EASE;
      railFill.style.background = 'linear-gradient(90deg,#2DD27E,' + A.c1 + ')';
      railFill.style.width = p;

      travelDoc.style.transition = 'left .8s ' + SPRING;
      travelDoc.style.left = p;

      parallax.style.transition = 'transform 1s ' + EASE;
      parallax.style.transform = 'translateX(' + (-step * 10) + 'px) translateY(' + (-step * 4) + 'px)';

      orbs.forEach((el, i) => {
        const active = i === step, done = i < step;
        el.style.left = at(i);
        el.style.transition = 'all .6s ' + SPRING;
        if (active) {
          el.style.background = 'linear-gradient(150deg,' + A.c1 + ',' + A.c2 + ')';
          el.style.color = '#fff';
          el.style.boxShadow = '0 0 0 6px rgba(' + A.glow + ',.16), 0 16px 34px rgba(' + A.glow + ',.55)';
          el.style.border = '1px solid rgba(255,255,255,.55)';
          el.style.transform = 'translate(-50%,-50%) scale(1.16)';
        } else if (done) {
          el.style.background = 'linear-gradient(150deg,#2DD27E,#23b76d)';
          el.style.color = '#fff';
          el.style.boxShadow = '0 10px 22px rgba(45,210,126,.4)';
          el.style.border = '1px solid rgba(255,255,255,.3)';
          el.style.transform = 'translate(-50%,-50%)';
        } else {
          el.style.background = 'rgba(255,255,255,.045)';
          el.style.color = 'rgba(220,230,255,.45)';
          el.style.boxShadow = 'inset 0 0 0 1px rgba(255,255,255,.08)';
          el.style.border = '1px solid rgba(255,255,255,.06)';
          el.style.transform = 'translate(-50%,-50%)';
        }
      });

      labels.forEach((el, i) => {
        const active = i === step, done = i < step;
        el.style.left = at(i);
        el.style.transform = 'translateX(-50%)';
        el.style.transition = 'all .5s ' + EASE;
        el.style.fontWeight = active ? '700' : '600';
        el.style.color = active ? '#fff' : (done ? 'rgba(190,255,222,.85)' : 'rgba(170,182,212,.5)');
      });

      scenes.forEach((el, i) => {
        const active = i === step;
        el.style.transition = 'all ' + (active ? '.75' : '.55') + 's ' + EASE;
        el.style.opacity = active ? '1' : '0';
        el.style.transform = active ? 'translateY(0) scale(1)' : 'translateY(30px) scale(.965)';
        el.style.filter = active ? 'blur(0px)' : 'blur(7px)';
        el.style.pointerEvents = active ? 'auto' : 'none';
      });

      if (step === 4) {
        seal.style.transition = 'all .55s ' + SPRING + ' .15s';
        seal.style.transform = 'scale(1) rotate(-12deg)';
        seal.style.opacity = '1';
        sigPath.style.transition = 'stroke-dashoffset 1.15s ease .35s';
        sigPath.style.strokeDashoffset = '0';
      } else {
        seal.style.transition = 'all .25s ease';
        seal.style.transform = 'scale(1.8) rotate(-12deg)';
        seal.style.opacity = '0';
        sigPath.style.transition = 'none';
        sigPath.style.strokeDashoffset = '330';
      }
    }

    function start() {
      if (sbhActiveTimer) clearInterval(sbhActiveTimer);
      sbhActiveTimer = null;
      if (!playing) return;
      sbhActiveTimer = setInterval(() => { step = (step + 1) % N; render(); }, PACE_MS[PACE]);
    }

    playBtn.addEventListener('click', () => {
      playing = !playing;
      playBtn.textContent = playing ? 'Pause' : 'Play';
      start();
    });

    // Accessibility: respect reduced motion - show the finished state, no loop.
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      step = 4; playing = false; playBtn.textContent = 'Play'; render();
    } else {
      render(); start();
    }
  }

  // Run on first load and after every Astro view transition; clear the timer
  // before a swap so navigations don't stack interval drivers.
  initSignBoxHero();
  document.addEventListener('astro:page-load', initSignBoxHero);
  document.addEventListener('astro:before-swap', () => {
    if (sbhActiveTimer) { clearInterval(sbhActiveTimer); sbhActiveTimer = null; }
  });
</script>
