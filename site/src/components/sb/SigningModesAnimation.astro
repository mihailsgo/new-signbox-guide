  const SBR_REF = 1060; // "Extra large" reference width from the handoff.

  function initSignboxRouting() {
    document.querySelectorAll<HTMLElement>('.signbox-routing').forEach((fig) => {
      const wrap = fig.querySelector<HTMLElement>('.sbr-wrap');
      const frame = fig.querySelector<HTMLElement>('.sbr-frame');
      if (!wrap || !frame) return;

      const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) frame.style.setProperty('--pstate', 'paused');

      const fitScale = () => {
        frame.style.width = SBR_REF + 'px';
        const scale = (wrap.clientWidth || SBR_REF) / SBR_REF;
        frame.style.transform = 'scale(' + scale + ')';
        wrap.style.height = (1000 * scale) + 'px';
      };

      // Re-init across view transitions without stacking observers.
      const prev = (fig as any).__sbrRO as ResizeObserver | undefined;
      if (prev) prev.disconnect();
      const ro = new ResizeObserver(fitScale);
      ro.observe(wrap);
      (fig as any).__sbrRO = ro;

      fitScale();
    });
  }

  initSignboxRouting();
  document.addEventListener('astro:page-load', initSignboxRouting);
  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll<HTMLElement>('.signbox-routing').forEach((fig) => {
      const ro = (fig as any).__sbrRO as ResizeObserver | undefined;
      if (ro) { ro.disconnect(); (fig as any).__sbrRO = undefined; }
    });
  });
</script>
