---
import '../../styles/signbox-anim.css';

interface Props { class?: string; caption?: string; showCaption?: boolean; }
const {
  class: className = '',
  caption = 'Parallel signing sends every invitation at once. Sequential signing unlocks each recipient only after the previous step is complete.',
  showCaption = true,
} = Astro.props;

const parallelRecipients = [
  { name: 'Legal', initials: 'LE', tone: 'blue' },
  { name: 'Finance', initials: 'FI', tone: 'gold' },
  { name: 'Supplier', initials: 'SU', tone: 'violet' },
];

const sequentialSteps = [
  { name: 'Legal', action: 'Signs', result: 'Signed', initials: 'LE' },
  { name: 'Finance', action: 'Signs', result: 'Signed', initials: 'FI' },
  { name: 'Director', action: 'Approves', result: 'Approved', initials: 'DI' },
];
---

<figure class={`sb-anim signing-modes ${className}`} role="group" aria-label="Parallel signing compared with sequential signing">
  <div class="sm-grid">
    <section class="sm-panel sm-parallel" aria-labelledby="parallel-title">
      <header class="sm-header">
        <div><h4 id="parallel-title">Parallel signing</h4><p>Everyone receives the request at once.</p></div>
        <span class="sm-complete"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>Completed</span>
      </header>

      <div class="sm-parallel-flow">
        <div class="sm-process">
          <span class="sm-brand"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 4 7v10l8 4 8-4V7z"/><path d="m4 7 8 4 8-4M12 11v10"/></svg>SignBox</span>
          <span class="sm-file"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 2h8l4 4v16H6z"/><path d="M14 2v5h5M9 13h6M9 17h4"/></svg></span>
          <strong>Supplier agreement</strong><small>Agreement.pdf · 3 recipients</small>
          <span class="sm-process-state"><i></i>Sent to all</span>
        </div>

        <div class="sm-branch" aria-hidden="true">
          <svg viewBox="0 0 64 220" preserveAspectRatio="none">
            <path d="M2 110H24C35 110 35 36 62 36"/><path d="M2 110H62"/><path d="M2 110H24C35 110 35 184 62 184"/>
          </svg>
          <span class="sm-mail sm-mail-1">✉</span><span class="sm-mail sm-mail-2">✉</span><span class="sm-mail sm-mail-3">✉</span>
        </div>

        <div class="sm-recipient-list">
          {parallelRecipients.map((recipient, index) => (
            <article class={`sm-recipient sm-recipient-${index + 1}`}>
              <span class={`sm-avatar ${recipient.tone}`} aria-hidden="true">{recipient.initials}</span>
              <div><strong>{recipient.name}</strong><small>Invitation received</small></div>
              <span class="sm-status-stack">
                <em class="sent">Sent</em><em class="waiting">Waiting</em><em class="done"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>Signed</em>
              </span>
            </article>
          ))}
        </div>
      </div>

      <div class="sm-timeline sm-timeline-parallel" aria-label="Started, waiting for recipients, completed">
        <span class="is-done"><i></i><b>Started</b></span><span class="is-done"><i></i><b>Waiting for recipients</b></span><span class="is-done"><i></i><b>Completed</b></span>
      </div>
    </section>

    <section class="sm-panel sm-sequential" aria-labelledby="sequential-title">
      <header class="sm-header">
        <div><h4 id="sequential-title">Sequential signing</h4><p>Each next step unlocks only after the previous step is done.</p></div>
        <span class="sm-complete"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>Completed</span>
      </header>

      <div class="sm-seq-flow">
        <div class="sm-seq-rail" aria-hidden="true"><i></i></div>
        {sequentialSteps.map((step, index) => (
          <article class={`sm-seq-step sm-seq-step-${index + 1}`}>
            <span class="sm-step-index">{index + 1}</span>
            <span class={`sm-avatar ${index === 1 ? 'gold' : 'blue'}`} aria-hidden="true">{step.initials}</span>
            <div><strong>{step.name}</strong><small>{step.action} in step {index + 1}</small></div>
            <span class="sm-lock-state"><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="5" y="10" width="14" height="10" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>Locked</span>
            <span class="sm-unlocked-state">Unlocked</span>
            <span class="sm-done-state"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m5 13 4 4L19 7"/></svg>{step.result}</span>
          </article>
        ))}
      </div>

      <div class="sm-timeline sm-timeline-sequential" aria-label="Started, step 1, step 2, approval, completed">
        {['Started', 'Step 1', 'Step 2', 'Approval', 'Completed'].map((label) => <span class="is-done"><i></i><b>{label}</b></span>)}
      </div>
    </section>
  </div>
  {showCaption && <figcaption class="sb-cap">{caption}</figcaption>}
</figure>

<style>
  .signing-modes{margin:0;display:flex;flex-direction:column;gap:14px}.sm-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px}
  .sm-panel{position:relative;overflow:hidden;display:flex;flex-direction:column;min-width:0;min-height:440px;border:1px solid var(--sb-border-strong);border-radius:20px;background:var(--sb-card);box-shadow:var(--sb-shadow-sm)}
  .sm-panel::before{content:"";position:absolute;inset:0 0 auto;height:3px;background:var(--sb-blue)}.sm-sequential::before{background:var(--sb-gold)}
  .sm-header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;padding:18px 18px 14px;border-bottom:1px solid var(--sb-border)}.sm-header h4{margin:0;color:var(--sb-ink);font-size:16px;line-height:1.25;letter-spacing:-.015em}.sm-header p{margin:4px 0 0;color:var(--sb-ink-soft);font-size:10.5px;line-height:1.4;max-width:31ch}.sm-complete{display:flex;align-items:center;gap:4px;padding:5px 7px;border-radius:7px;background:var(--sb-success-soft);color:var(--sb-success);font-size:8px;font-weight:800;white-space:nowrap}.sm-complete svg{width:10px;height:10px;fill:none;stroke:currentColor;stroke-width:3;stroke-linecap:round;stroke-linejoin:round}
  .sm-parallel-flow{display:grid;grid-template-columns:104px 46px minmax(0,1fr);align-items:center;gap:0;padding:18px;min-height:286px;flex:1;background:linear-gradient(180deg,color-mix(in srgb,var(--sb-blue) 3%,transparent),transparent)}
  .sm-process{align-self:center;display:flex;flex-direction:column;align-items:flex-start;min-width:0;padding:11px;border:1px solid var(--sb-border-strong);border-radius:13px;background:var(--sb-card-2);box-shadow:var(--sb-shadow-sm)}.sm-brand{display:flex;align-items:center;gap:5px;color:var(--sb-ink);font-size:8px;font-weight:850}.sm-brand svg{width:12px;height:12px;fill:none;stroke:var(--sb-gold);stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}.sm-file{width:39px;height:48px;display:grid;place-items:center;margin:15px auto 10px;border-radius:8px;background:color-mix(in srgb,var(--sb-blue) 10%,var(--sb-card));color:var(--sb-blue)}.sm-file svg{width:22px;height:27px;fill:none;stroke:currentColor;stroke-width:1.5;stroke-linecap:round;stroke-linejoin:round}.sm-process>strong{font-size:9px;line-height:1.3}.sm-process>small{font-size:7px;color:var(--sb-muted);margin-top:2px}.sm-process-state{display:flex;align-items:center;gap:5px;width:100%;margin-top:12px;padding-top:8px;border-top:1px solid var(--sb-border);color:var(--sb-blue);font-size:7.5px;font-weight:750}.sm-process-state i{width:6px;height:6px;border-radius:50%;background:currentColor}
  .sm-branch{position:relative;align-self:stretch}.sm-branch svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible}.sm-branch path{fill:none;stroke:color-mix(in srgb,var(--sb-blue) 65%,var(--sb-border));stroke-width:1.6;stroke-dasharray:4 4;vector-effect:non-scaling-stroke}.sm-mail{position:absolute;left:8px;width:18px;height:18px;display:grid;place-items:center;border:1px solid color-mix(in srgb,var(--sb-blue) 40%,var(--sb-border));border-radius:6px;background:var(--sb-card);color:var(--sb-blue);font-size:9px;box-shadow:var(--sb-shadow-sm)}.sm-mail-1{top:calc(16% - 9px)}.sm-mail-2{top:calc(50% - 9px)}.sm-mail-3{top:calc(84% - 9px)}
  .sm-recipient-list{display:flex;flex-direction:column;gap:9px}.sm-recipient{display:grid;grid-template-columns:30px minmax(56px,1fr) auto;align-items:center;gap:8px;min-width:0;padding:9px;border:1px solid var(--sb-border);border-radius:11px;background:var(--sb-card-2)}.sm-avatar{width:30px;height:30px;display:grid;place-items:center;border-radius:50%;background:color-mix(in srgb,var(--sb-blue) 14%,var(--sb-card));color:var(--sb-blue);font-size:8px;font-weight:850}.sm-avatar.gold{background:color-mix(in srgb,var(--sb-gold) 16%,var(--sb-card));color:var(--sb-gold)}.sm-avatar.violet{background:color-mix(in srgb,#7857d9 14%,var(--sb-card));color:#7857d9}.sm-recipient>div{display:flex;flex-direction:column;min-width:0}.sm-recipient strong{color:var(--sb-ink);font-size:9.5px}.sm-recipient small{color:var(--sb-muted);font-size:7.2px}.sm-status-stack{position:relative;width:42px;height:19px}.sm-status-stack em{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:3px;border:1px solid var(--sb-border);border-radius:6px;background:var(--sb-card);color:var(--sb-muted);font-size:7px;font-style:normal;font-weight:800;opacity:0}.sm-status-stack .done{opacity:1;border-color:color-mix(in srgb,var(--sb-success) 28%,var(--sb-border));background:var(--sb-success-soft);color:var(--sb-success)}.sm-status-stack svg{width:8px;height:8px;fill:none;stroke:currentColor;stroke-width:3;stroke-linecap:round;stroke-linejoin:round}
  .sm-seq-flow{position:relative;display:flex;flex-direction:column;justify-content:center;gap:10px;padding:19px 18px 14px 52px;min-height:286px;flex:1;background:linear-gradient(180deg,color-mix(in srgb,var(--sb-gold) 3%,transparent),transparent)}.sm-seq-rail{position:absolute;left:31px;top:45px;bottom:45px;width:2px;background:var(--sb-border-strong)}.sm-seq-rail i{display:block;width:100%;height:100%;background:var(--sb-gold);transform-origin:top}.sm-seq-step{position:relative;display:grid;grid-template-columns:30px minmax(66px,1fr) auto;align-items:center;gap:9px;min-height:58px;padding:9px;border:1px solid var(--sb-border);border-radius:12px;background:var(--sb-card-2);box-shadow:0 7px 18px -17px rgba(15,27,46,.5)}.sm-step-index{position:absolute;left:-32px;width:22px;height:22px;display:grid;place-items:center;border:2px solid var(--sb-gold);border-radius:50%;background:var(--sb-card);color:var(--sb-gold);font-size:8px;font-weight:850;z-index:2}.sm-seq-step>div{display:flex;flex-direction:column}.sm-seq-step strong{font-size:9.5px;color:var(--sb-ink)}.sm-seq-step small{font-size:7.3px;color:var(--sb-muted)}.sm-lock-state,.sm-unlocked-state,.sm-done-state{grid-column:3;grid-row:1;display:flex;align-items:center;gap:3px;padding:5px 6px;border-radius:6px;font-size:7px;font-weight:800;white-space:nowrap}.sm-lock-state{background:var(--sb-card);border:1px solid var(--sb-border);color:var(--sb-muted);opacity:0}.sm-lock-state svg{width:9px;height:9px;fill:none;stroke:currentColor;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}.sm-unlocked-state{background:color-mix(in srgb,var(--sb-gold) 12%,var(--sb-card));color:var(--sb-gold);opacity:0}.sm-done-state{background:var(--sb-success-soft);color:var(--sb-success)}.sm-done-state svg{width:9px;height:9px;fill:none;stroke:currentColor;stroke-width:3;stroke-linecap:round;stroke-linejoin:round}
  .sm-timeline{position:relative;display:flex;justify-content:space-between;gap:5px;margin:0 18px 17px;padding-top:14px;border-top:1px solid var(--sb-border)}.sm-timeline::before{content:"";position:absolute;left:8px;right:8px;top:18px;height:2px;background:var(--sb-success)}.sm-timeline span{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:5px;max-width:80px;text-align:center}.sm-timeline i{width:9px;height:9px;border:2px solid var(--sb-success);border-radius:50%;background:var(--sb-card)}.sm-timeline b{color:var(--sb-ink-soft);font-size:6.8px;line-height:1.25}.sm-timeline-sequential b{font-size:6.4px}.sm-timeline-sequential span{max-width:48px}
  @media (prefers-reduced-motion:no-preference){
    :global(.is-animating).signing-modes .sm-parallel .sm-branch path{animation:sbDash 1.4s linear infinite}
    :global(.is-animating).signing-modes .sm-parallel .sm-mail{animation:smMail 10s cubic-bezier(.22,1,.36,1) infinite}
    :global(.is-animating).signing-modes .sm-parallel .sent{animation:smSent 10s linear infinite}:global(.is-animating).signing-modes .sm-parallel .waiting{animation:smWaiting 10s linear infinite}:global(.is-animating).signing-modes .sm-parallel .done{animation:smParallelDone 10s cubic-bezier(.22,1,.36,1) infinite}
    :global(.is-animating).signing-modes .sm-parallel .sm-recipient-2 .done{animation-delay:.35s}:global(.is-animating).signing-modes .sm-parallel .sm-recipient-3 .done{animation-delay:.7s}
    :global(.is-animating).signing-modes .sm-sequential .sm-seq-rail i{animation:smRail 10s cubic-bezier(.22,1,.36,1) infinite}
    :global(.is-animating).signing-modes .sm-sequential .sm-done-state{animation:smSeqDone 10s cubic-bezier(.22,1,.36,1) infinite}.sm-sequential :global(.is-animating){}
    :global(.is-animating).signing-modes .sm-sequential .sm-lock-state{animation:smLock 10s linear infinite}
    :global(.is-animating).signing-modes .sm-sequential .sm-unlocked-state{animation:smUnlock 10s linear infinite}
    :global(.is-animating).signing-modes .sm-sequential .sm-seq-step-2>*:is(.sm-lock-state,.sm-unlocked-state,.sm-done-state){animation-delay:2.1s}
    :global(.is-animating).signing-modes .sm-sequential .sm-seq-step-3>*:is(.sm-lock-state,.sm-unlocked-state,.sm-done-state){animation-delay:4.2s}
    :global(.is-animating).signing-modes .sm-complete{animation:smComplete 10s cubic-bezier(.22,1,.36,1) infinite}
  }
  @keyframes smMail{0%,10%{opacity:0;transform:translateX(-15px)}13%,21%{opacity:1;transform:translateX(22px)}24%,100%{opacity:0;transform:translateX(25px)}}@keyframes smSent{0%,18%{opacity:0}21%,31%{opacity:1}34%,100%{opacity:0}}@keyframes smWaiting{0%,29%{opacity:0}33%,43%{opacity:1}47%,100%{opacity:0}}@keyframes smParallelDone{0%,42%{opacity:0;transform:scale(.8)}47%,97%{opacity:1;transform:scale(1)}100%{opacity:0}}
  @keyframes smRail{0%,8%{transform:scaleY(.05)}69%,100%{transform:scaleY(1)}}@keyframes smLock{0%,5%{opacity:1}12%,100%{opacity:0}}@keyframes smUnlock{0%,6%{opacity:0}11%,17%{opacity:1}22%,100%{opacity:0}}@keyframes smSeqDone{0%,17%{opacity:0;transform:scale(.8)}22%,97%{opacity:1;transform:scale(1)}100%{opacity:0}}@keyframes smComplete{0%,67%{opacity:0;transform:translateY(3px)}72%,97%{opacity:1;transform:none}100%{opacity:0}}
  @media (max-width:860px){.sm-grid{grid-template-columns:1fr}.sm-panel{min-height:420px}}
  @media (max-width:440px){.sm-header{padding:16px 13px 12px}.sm-header p{font-size:9.5px}.sm-parallel-flow{grid-template-columns:86px 31px minmax(0,1fr);padding:14px 11px}.sm-process{padding:8px}.sm-recipient{grid-template-columns:26px minmax(42px,1fr) auto;gap:6px;padding:7px}.sm-avatar{width:26px;height:26px}.sm-status-stack{width:38px}.sm-seq-flow{padding-left:43px;padding-right:11px}.sm-seq-rail{left:25px}.sm-step-index{left:-29px}.sm-timeline{margin-inline:12px}}
</style>

<script>
  function initSigningModeAnimations() {
    document.querySelectorAll('.signing-modes').forEach((element) => {
      if (element.hasAttribute('data-observed')) return;
      element.setAttribute('data-observed', 'true');
      const observer = new IntersectionObserver(([entry]) => element.classList.toggle('is-animating', entry.isIntersecting), { threshold: 0.1 });
      observer.observe(element);
    });
  }
  initSigningModeAnimations();
  document.addEventListener('astro:after-swap', initSigningModeAnimations);
</script>
