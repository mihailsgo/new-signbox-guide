---
/**
 * SigningModesAnimation - Parallel vs. sequential signing.
 *
 * 1:1 port of the design handoff `signbox-routing-reference.html`
 * (design_handoff_routing_animation). One CSS variable (--cycle) drives the
 * whole loop; every keyframe is authored as a percentage of that cycle so both
 * rows stay in lockstep and the speed difference (sequential one-by-one vs.
 * parallel all-at-once) is the takeaway.
 *
 * Defaults are hard-coded from the handoff: zoom "Extra large" (ref 1060),
 * look "Midnight glass", pace "Standard" (11s) - all inline on .sbr-frame.
 * The demo's play/pause + zoom/look/pace <select> controls are intentionally
 * dropped here; only fit-to-width scaling and reduced-motion are wired in JS.
 *
 * Fonts (Manrope / Space Grotesk) are already loaded globally in Head.astro.
 *
 * Ambient keyframes are prefixed `sbr*` (sbrFloat/sbrSweep/...) on purpose:
 * SignBoxHero.astro declares same-named global keyframes (sbFloat, sbSweep, ...)
 * and both render on the homepage, so unprefixed names would clobber each other.
 *
 * NOTE (manual step): avatars still load from i.pravatar.cc placeholders.
 * Replace the six <img src> with real TrustLynx headshots before shipping -
 * same three people in both rows (2 imgs per person), circular + 2px ring.
 */
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---

<figure class={`sb-anim signbox-routing ${className}`} role="group" aria-label="Parallel signing compared with sequential signing">
<!-- WRAPPER (fluid) -> FRAME (fixed design, scaled to fit width) -->
<div class="sbr-wrap" style="width:100%; max-width:1280px; margin:0 auto; position:relative; overflow:hidden;">
<div class="sbr-frame" style="--cycle:11s; --pstate:running; --acc1:#3D7BFF; --acc2:#6AA1FF; --glow:61,123,255; --panel-bg:linear-gradient(165deg,#0c1326 0%,#0a0f1f 55%,#0b1024 100%); --panel-border:rgba(120,150,220,.14); --panel-bloom:radial-gradient(620px 320px at 25% -10%, rgba(61,123,255,.2), transparent 60%), radial-gradient(520px 320px at 100% 110%, rgba(45,210,126,.15), transparent 60%); --grid-op:.5; --grid-col:rgba(140,165,225,.05); width:1060px; height:1000px; transform-origin:top left; background:radial-gradient(1200px 600px at 50% -10%, #eef2f9, #e1e7f1 60%, #d8dfeb); font-family:'Manrope',system-ui,sans-serif; color:#1B2436; padding:40px; display:flex; flex-direction:column; overflow:hidden;">

  <!-- HEADER -->
  <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:24px;">
    <div>
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
        <div style="width:9px; height:9px; border-radius:3px; background:linear-gradient(135deg,#3D7BFF,#6AA1FF);"></div>
        <span style="font-size:12.5px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; color:#6B7689;">TrustLynx SignBox · routing modes</span>
      </div>
      <h1 style="margin:0; font-family:'Space Grotesk',sans-serif; font-size:34px; font-weight:700; letter-spacing:-.5px; color:#141B2B;">Parallel vs. sequential signing</h1>
    </div>
    <div style="display:flex; align-items:center; gap:18px;">
      <div style="display:flex; align-items:center; gap:16px; font-size:12.5px; font-weight:600; color:#5b6b85;">
        <span style="display:flex; align-items:center; gap:7px;"><span style="width:10px;height:10px;border-radius:50%;background:#3D7BFF;"></span>Signer</span>
        <span style="display:flex; align-items:center; gap:7px;"><span style="width:10px;height:10px;border-radius:50%;background:#8B6BFF;"></span>Approver</span>
      </div>
    </div>
  </div>

  <!-- PANEL -->
  <div style="display:flex; gap:34px; flex:1; min-height:0;">
    <div style="flex:1; min-width:0; position:relative; border-radius:22px; padding:24px 26px; display:flex; flex-direction:column; overflow:hidden; background:var(--panel-bg); border:1px solid var(--panel-border); box-shadow:0 30px 70px -30px rgba(10,16,36,.8), inset 0 1px 0 rgba(255,255,255,.05);">
      <div style="position:absolute; inset:0; pointer-events:none; background:var(--panel-bloom);"></div>
      <div style="position:absolute; inset:0; pointer-events:none; opacity:var(--grid-op); background-image:linear-gradient(var(--grid-col) 1px, transparent 1px), linear-gradient(90deg, var(--grid-col) 1px, transparent 1px); background-size:34px 34px;"></div>
      <div style="position:absolute; top:0; left:0; width:120px; height:100%; pointer-events:none; background:linear-gradient(90deg, transparent, rgba(255,255,255,.05), transparent); animation:sbrSweep 8s ease-in-out infinite; animation-play-state:var(--pstate);"></div>
      <div class="ambient" style="position:absolute; inset:0; pointer-events:none;">
        <span style="position:absolute; left:16%; top:18%; width:4px; height:4px; border-radius:50%; background:#6AA1FF; animation:sbrTwinkle 4s ease-in-out infinite; animation-play-state:var(--pstate);"></span>
        <span style="position:absolute; left:82%; top:40%; width:3px; height:3px; border-radius:50%; background:#9bd9b8; animation:sbrTwinkle 5.5s ease-in-out infinite .6s; animation-play-state:var(--pstate);"></span>
        <span style="position:absolute; left:60%; top:80%; width:5px; height:5px; border-radius:50%; background:#6AA1FF; animation:sbrDrift 9s linear infinite alternate; animation-play-state:var(--pstate);"></span>
        <span style="position:absolute; left:30%; top:88%; width:3px; height:3px; border-radius:50%; background:#cbd9ff; animation:sbrTwinkle 6s ease-in-out infinite 1.2s; animation-play-state:var(--pstate);"></span>
        <span style="position:absolute; left:90%; top:70%; width:4px; height:4px; border-radius:50%; background:#7fe0ad; animation:sbrDrift 11s linear infinite alternate; animation-play-state:var(--pstate);"></span>
      </div>

      <!-- ================= Sequential ================= -->
      <div style="position:relative; flex:1; min-height:0; display:flex; flex-direction:column; padding-top:14px;">
        <div style="display:flex; align-items:baseline; gap:9px; margin-bottom:10px;">
          <span style="font-family:'Space Grotesk',sans-serif; font-size:16px; font-weight:600; color:#eaf0ff;">Sequential</span>
          <span style="font-size:12.5px; color:#8da0c8;">one after another · order enforced</span>
        </div>
        <div style="flex:1; display:flex; align-items:center; gap:8px;">
          <div style="position:relative; flex:none; width:62px; height:62px; border-radius:18px; background:linear-gradient(150deg,var(--acc1),#2a5fd6); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px; box-shadow:0 0 0 5px rgba(var(--glow),.13), 0 16px 30px rgba(var(--glow),.5); animation:sbrFloat 4s ease-in-out infinite; animation-play-state:var(--pstate);">
            <div style="position:absolute; inset:-3px; border-radius:20px; border:1px dashed rgba(255,255,255,.3); animation:sbrSpin 18s linear infinite; animation-play-state:var(--pstate);"></div>
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2.3"/><circle cx="5" cy="18" r="2.3"/><circle cx="19" cy="12" r="2.3"/><path d="M7.2 7 16.8 11M7.2 17 16.8 13"/></svg>
            <span style="font-size:7.5px; font-weight:800; color:#fff; letter-spacing:.3px;">SignBox</span>
          </div>
          <div style="flex:1; height:4px; background:rgba(255,255,255,.07); border-radius:99px; position:relative; overflow:hidden;"><div style="position:absolute; left:0; top:0; height:100%; width:0; border-radius:99px; background:linear-gradient(90deg,var(--acc1),var(--acc2)); box-shadow:0 0 12px rgba(var(--glow),.7); animation:seqLine1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div></div>
          <div style="position:relative; flex:none; width:114px; padding:13px 8px; border-radius:15px; background:linear-gradient(160deg,rgba(255,255,255,.08),rgba(255,255,255,.02)); border:1px solid rgba(140,165,225,.18); text-align:center;">
            <div style="position:absolute; inset:-10px; z-index:-1; border-radius:22px; background:radial-gradient(circle,rgba(var(--glow),.5),transparent 70%); opacity:0; animation:actS1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
            <div style="position:absolute; inset:-2px; z-index:-1; border-radius:17px; border:2px solid #2DD27E; box-shadow:0 0 16px rgba(45,210,126,.55); opacity:0; animation:doneS1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
            <div style="position:relative; width:46px; height:46px; margin:0 auto 8px;"><img src="https://i.pravatar.cc/120?img=12" alt="Legal" style="width:46px; height:46px; border-radius:50%; object-fit:cover; border:2px solid rgba(120,160,255,.6);"></div>
            <div style="color:#eaf0ff; font-size:12.5px; font-weight:700;">Legal</div>
            <div style="margin-top:6px; font-size:9.5px; font-weight:700; color:#bcd0ff; background:rgba(var(--glow),.18); border:1px solid rgba(120,160,255,.3); padding:2px 7px; border-radius:5px; display:inline-block;">Signer</div>
            <div style="position:absolute; top:-7px; right:-7px; width:24px; height:24px; border-radius:50%; background:linear-gradient(150deg,#2DD27E,#1ea862); display:flex; align-items:center; justify-content:center; box-shadow:0 6px 14px rgba(45,210,126,.5); opacity:0; animation:checkS1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></div>
          </div>
          <div style="flex:1; height:4px; background:rgba(255,255,255,.07); border-radius:99px; position:relative; overflow:hidden;"><div style="position:absolute; left:0; top:0; height:100%; width:0; border-radius:99px; background:linear-gradient(90deg,var(--acc1),var(--acc2)); box-shadow:0 0 12px rgba(var(--glow),.7); animation:seqLine2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div></div>
          <div style="position:relative; flex:none; width:114px; padding:13px 8px; border-radius:15px; background:linear-gradient(160deg,rgba(255,255,255,.08),rgba(255,255,255,.02)); border:1px solid rgba(140,165,225,.18); text-align:center;">
            <div style="position:absolute; inset:-10px; z-index:-1; border-radius:22px; background:radial-gradient(circle,rgba(var(--glow),.5),transparent 70%); opacity:0; animation:actS2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
            <div style="position:absolute; inset:-2px; z-index:-1; border-radius:17px; border:2px solid #2DD27E; box-shadow:0 0 16px rgba(45,210,126,.55); opacity:0; animation:doneS2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
            <div style="position:relative; width:46px; height:46px; margin:0 auto 8px;"><img src="https://i.pravatar.cc/120?img=47" alt="Finance" style="width:46px; height:46px; border-radius:50%; object-fit:cover; border:2px solid rgba(120,160,255,.6);"></div>
            <div style="color:#eaf0ff; font-size:12.5px; font-weight:700;">Finance</div>
            <div style="margin-top:6px; font-size:9.5px; font-weight:700; color:#bcd0ff; background:rgba(var(--glow),.18); border:1px solid rgba(120,160,255,.3); padding:2px 7px; border-radius:5px; display:inline-block;">Signer</div>
            <div style="position:absolute; top:-7px; right:-7px; width:24px; height:24px; border-radius:50%; background:linear-gradient(150deg,#2DD27E,#1ea862); display:flex; align-items:center; justify-content:center; box-shadow:0 6px 14px rgba(45,210,126,.5); opacity:0; animation:checkS2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></div>
          </div>
          <div style="flex:1; height:4px; background:rgba(255,255,255,.07); border-radius:99px; position:relative; overflow:hidden;"><div style="position:absolute; left:0; top:0; height:100%; width:0; border-radius:99px; background:linear-gradient(90deg,#8B6BFF,#b49bff); box-shadow:0 0 12px rgba(139,107,255,.7); animation:seqLine3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div></div>
          <div style="position:relative; flex:none; width:114px; padding:13px 8px; border-radius:15px; background:linear-gradient(160deg,rgba(255,255,255,.08),rgba(255,255,255,.02)); border:1px solid rgba(170,150,255,.22); text-align:center;">
            <div style="position:absolute; inset:-10px; z-index:-1; border-radius:22px; background:radial-gradient(circle,rgba(139,107,255,.5),transparent 70%); opacity:0; animation:actS3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
            <div style="position:absolute; inset:-2px; z-index:-1; border-radius:17px; border:2px solid #2DD27E; box-shadow:0 0 16px rgba(45,210,126,.55); opacity:0; animation:doneS3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
            <div style="position:relative; width:46px; height:46px; margin:0 auto 8px;"><img src="https://i.pravatar.cc/120?img=68" alt="Director" style="width:46px; height:46px; border-radius:50%; object-fit:cover; border:2px solid rgba(170,150,255,.65);"></div>
            <div style="color:#eaf0ff; font-size:12.5px; font-weight:700;">Director</div>
            <div style="margin-top:6px; font-size:9.5px; font-weight:700; color:#d6ccff; background:rgba(139,107,255,.18); border:1px solid rgba(170,150,255,.3); padding:2px 7px; border-radius:5px; display:inline-block;">Approver</div>
            <div style="position:absolute; top:-7px; right:-7px; width:24px; height:24px; border-radius:50%; background:linear-gradient(150deg,#2DD27E,#1ea862); display:flex; align-items:center; justify-content:center; box-shadow:0 6px 14px rgba(45,210,126,.5); opacity:0; animation:checkS3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></div>
          </div>
          <div style="flex:none; width:30px; height:4px; background:rgba(255,255,255,.07); border-radius:99px; position:relative; overflow:hidden; margin:0 1px;"><div style="position:absolute; left:0; top:0; height:100%; width:0; border-radius:99px; background:linear-gradient(90deg,var(--acc1),var(--acc2)); box-shadow:0 0 12px rgba(var(--glow),.7); animation:seqLine1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div></div>
          <!-- DOCUMENT (sequential: slots fill 1->2->3) -->
          <div style="position:relative; flex:none; width:196px; padding:15px 15px 13px; border-radius:14px; background:linear-gradient(160deg,#ffffff,#eaf1fb); box-shadow:0 22px 44px -18px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.4); animation:sbrFloat 4.6s ease-in-out infinite; animation-play-state:var(--pstate);">
            <span style="position:absolute; top:0; right:0; border-width:0 16px 16px 0; border-style:solid; border-color:transparent #cdd9ee transparent transparent;"></span>
            <div style="display:flex; align-items:center; gap:6px; margin-bottom:9px;">
              <span style="font-family:'Space Grotesk',sans-serif; font-size:11px; font-weight:700; color:#1b2436;">Agreement.pdf</span>
              <span style="margin-left:auto; font-size:7px; font-weight:800; color:#fff; background:#3D7BFF; border-radius:3px; padding:2px 5px; letter-spacing:.3px;">PDF</span>
            </div>
            <span style="display:block; height:3px; border-radius:2px; background:#dde5f1; width:100%; margin-bottom:5px;"></span>
            <span style="display:block; height:3px; border-radius:2px; background:#e6ecf6; width:72%; margin-bottom:11px;"></span>
            <div style="font-size:7.5px; font-weight:800; letter-spacing:.4px; color:#9aa9c4; text-transform:uppercase; margin-bottom:6px;">Signatures · collected in order</div>
            <div style="display:flex; flex-direction:column; gap:6px;">
              <div style="position:relative; display:flex; align-items:center; gap:7px; padding:5px 8px; border-radius:8px; background:#f4f7fc; border:1px solid #e7ecf4; overflow:hidden;">
                <div style="position:absolute; inset:0; border-radius:8px; background:rgba(45,210,126,.1); border:1px solid rgba(45,210,126,.5); opacity:0; animation:doneS1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
                <span style="position:relative; font-size:8.5px; font-weight:700; color:#5b6b85; width:42px; flex:none;">Legal</span>
                <div style="position:relative; flex:1; height:18px;">
                  <div style="position:absolute; left:0; right:0; bottom:3px; height:1px; background:#cdd6e4;"></div>
                  <svg width="100%" height="18" viewBox="0 0 108 20" preserveAspectRatio="none" style="position:absolute; left:0; bottom:0; overflow:visible;"><path d="M4 14 C 9 4 13 4 16 13 C 18 19 23 17 27 11 C 32 4 38 4 41 14 C 44 21 50 16 56 11 C 63 5 70 17 79 11 C 88 5 95 14 104 9" stroke="var(--acc1)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="180" style="stroke-dashoffset:180; animation:sigS1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"/></svg>
                </div>
                <span style="position:relative; flex:none; color:#2DD27E; opacity:0; animation:doneS1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></span>
              </div>
              <div style="position:relative; display:flex; align-items:center; gap:7px; padding:5px 8px; border-radius:8px; background:#f4f7fc; border:1px solid #e7ecf4; overflow:hidden;">
                <div style="position:absolute; inset:0; border-radius:8px; background:rgba(45,210,126,.1); border:1px solid rgba(45,210,126,.5); opacity:0; animation:doneS2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
                <span style="position:relative; font-size:8.5px; font-weight:700; color:#5b6b85; width:42px; flex:none;">Finance</span>
                <div style="position:relative; flex:1; height:18px;">
                  <div style="position:absolute; left:0; right:0; bottom:3px; height:1px; background:#cdd6e4;"></div>
                  <svg width="100%" height="18" viewBox="0 0 108 20" preserveAspectRatio="none" style="position:absolute; left:0; bottom:0; overflow:visible;"><path d="M4 13 C 8 5 13 3 16 12 C 19 20 24 16 28 10 C 33 3 38 5 42 13 C 45 20 51 17 57 12 C 64 6 71 16 80 10 C 89 5 96 13 104 8" stroke="var(--acc1)" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="180" style="stroke-dashoffset:180; animation:sigS2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"/></svg>
                </div>
                <span style="position:relative; flex:none; color:#2DD27E; opacity:0; animation:doneS2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></span>
              </div>
              <div style="position:relative; display:flex; align-items:center; gap:7px; padding:5px 8px; border-radius:8px; background:#f4f7fc; border:1px solid #e7ecf4; overflow:hidden;">
                <div style="position:absolute; inset:0; border-radius:8px; background:rgba(45,210,126,.1); border:1px solid rgba(45,210,126,.5); opacity:0; animation:doneS3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
                <span style="position:relative; font-size:8.5px; font-weight:700; color:#5b6b85; width:42px; flex:none;">Director</span>
                <div style="position:relative; flex:1; height:18px;">
                  <div style="position:absolute; left:0; right:0; bottom:3px; height:1px; background:#cdd6e4;"></div>
                  <svg width="100%" height="18" viewBox="0 0 108 20" preserveAspectRatio="none" style="position:absolute; left:0; bottom:0; overflow:visible;"><path d="M4 14 C 10 4 14 5 17 13 C 19 19 25 16 29 11 C 34 4 39 4 43 13 C 46 21 52 16 58 11 C 65 5 72 17 81 11 C 90 5 97 14 104 9" stroke="#8B6BFF" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="180" style="stroke-dashoffset:180; animation:sigS3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"/></svg>
                </div>
                <span style="position:relative; flex:none; color:#2DD27E; opacity:0; animation:doneS3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></span>
              </div>
            </div>
            <div style="position:absolute; top:-9px; right:-9px; display:flex; align-items:center; gap:4px; padding:4px 8px; border-radius:99px; background:linear-gradient(150deg,#2DD27E,#1ea862); box-shadow:0 6px 16px rgba(45,210,126,.55); opacity:0; animation:docStampS var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg><span style="font-size:8px; font-weight:800; color:#fff; letter-spacing:.2px;">Signed</span></div>
