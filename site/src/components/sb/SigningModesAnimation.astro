        </div>
        <div style="display:flex; align-items:center; gap:12px; margin-top:8px;">
          <div style="flex:1; height:6px; background:rgba(255,255,255,.08); border-radius:99px; overflow:hidden;"><div style="height:100%; width:6%; border-radius:99px; background:linear-gradient(90deg,var(--acc1),var(--acc2)); box-shadow:0 0 10px rgba(var(--glow),.6); animation:seqBar var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div></div>
          <span style="flex:none; display:flex; align-items:center; gap:6px; font-size:11.5px; font-weight:700; color:#8ff0bd; opacity:0; animation:seqComplete var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2DD27E" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg>All signed · in order</span>
        </div>
      </div>

      <div style="position:relative; height:1px; background:rgba(140,165,225,.14); margin:16px 0;"></div>

      <!-- ================= Parallel ================= -->
      <div style="position:relative; flex:1; min-height:0; display:flex; flex-direction:column;">
        <div style="display:flex; align-items:baseline; gap:9px; margin-bottom:10px;">
          <span style="font-family:'Space Grotesk',sans-serif; font-size:16px; font-weight:600; color:#eaf0ff;">Parallel</span>
          <span style="font-size:12.5px; color:#8da0c8;">all at once · any order</span>
