---
/**
 * BusinessWorkflowExamples.astro - three real-world workflow cards with a small
 * timeline inside each. Subtle hover lift + timeline highlight only (no looping
 * animation). Theme-aware.
 */
import '../../styles/signbox-anim.css';
interface Props { class?: string; }
const { class: className = '' } = Astro.props;

const cards = [
  {
    title: 'HR contract',
    icon: '<path d="M16 21v-2a4 4 0 0 0-8 0v2"/><circle cx="12" cy="7" r="4"/>',
    steps: [
      'HR uploads the employment agreement.',
      'Employee signs with Smart-ID.',
      'Final signed container is stored.',
    ],
    chips: [{ t: 'Smart-ID', c: '' }, { t: 'Stored', c: 'green' }],
  },
  {
    title: 'Supplier agreement',
    icon: '<path d="M3 21V8l9-5 9 5v13"/><path d="M9 21v-6h6v6"/>',
    steps: [
      'Initiator adds supplier and internal approver.',
      'Supplier signs externally.',
      'Internal user tracks progress.',
    ],
    chips: [{ t: 'External', c: 'gold' }, { t: 'Tracked', c: '' }],
  },
  {
    title: 'Board decision',
    icon: '<path d="M12 3l2.5 5 5.5.8-4 3.9 1 5.5L12 21l-5-2.8 1-5.5-4-3.9 5.5-.8z"/>',
    steps: [
      'Document is routed through several people.',
      'Sequential signing controls the order.',
      'Final validated container is produced.',
    ],
    chips: [{ t: 'Sequential', c: '' }, { t: 'Validated', c: 'green' }],
  },
];
---
<div class={`sb-anim bw ${className}`}>
  <div class="bw-grid">
    {cards.map((card) => (
      <article class="bw-card">
        <div class="bw-head">
          <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={card.icon} /></span>
          <div class="t">{card.title}</div>
        </div>
        <div class="bw-tl">
          {card.steps.map((step, i) => (
            <div class="bw-stepline">
              <div class="marker"><div class="num">{i + 1}</div><div class="bar"></div></div>
              <div class="tx">{step}</div>
            </div>
          ))}
        </div>
        <div class="bw-foot">
          {card.chips.map((chip) => (
            <span class={`sb-chip ${chip.c}`}>{chip.t}</span>
          ))}
        </div>
      </article>
    ))}
  </div>
</div>

<style>
  .bw{margin:0;}
  .bw-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
  .bw-card{border-radius:18px;padding:20px;background:var(--sb-card);border:1px solid var(--sb-border);box-shadow:var(--sb-shadow-sm);
    transition:transform .3s ease,box-shadow .3s ease,border-color .3s ease;display:flex;flex-direction:column;gap:16px;}
  .bw-card:hover{transform:translateY(-5px);box-shadow:0 20px 40px -16px rgba(15,27,46,.30);border-color:color-mix(in srgb,var(--sb-gold) 40%,var(--sb-border));}
  .bw-head{display:flex;align-items:center;gap:11px;}
  .bw-head .ic{width:40px;height:40px;border-radius:12px;display:grid;place-items:center;flex:none;color:#fff;background:linear-gradient(160deg,var(--sb-navy),var(--sb-blue));}
  .bw-head .ic svg{width:20px;height:20px;}
  .bw-head .t{font-size:15px;font-weight:800;letter-spacing:-.01em;}
  .bw-tl{display:flex;flex-direction:column;gap:0;position:relative;}
  .bw-stepline{display:flex;gap:11px;position:relative;padding-bottom:14px;}
  .bw-stepline:last-child{padding-bottom:0;}
  .bw-stepline .marker{display:flex;flex-direction:column;align-items:center;flex:none;}
  .bw-stepline .num{width:24px;height:24px;border-radius:999px;display:grid;place-items:center;font-size:11px;font-weight:800;
    background:var(--sb-card-2);border:1px solid var(--sb-border-strong);color:var(--sb-ink-soft);transition:background .3s ease,color .3s ease,border-color .3s ease;}
  .bw-stepline .bar{width:2px;flex:1;background:var(--sb-border-strong);margin-top:3px;transition:background .3s ease;}
  .bw-stepline:last-child .bar{display:none;}
  .bw-stepline .tx{font-size:12.5px;color:var(--sb-ink-soft);font-weight:600;padding-top:3px;line-height:1.35;}
  .bw-card:hover .bw-stepline .num{background:linear-gradient(160deg,var(--sb-gold),var(--sb-gold-2));border-color:transparent;color:#fff;}
  .bw-card:hover .bw-stepline .bar{background:color-mix(in srgb,var(--sb-gold) 55%,transparent);}
  .bw-foot{display:flex;gap:6px;flex-wrap:wrap;}

  html[data-theme="dark"] .bw-head .ic{background:linear-gradient(160deg,#1b2a52,#23408e);}
  html[data-theme="dark"] .bw-card:hover{box-shadow:0 24px 50px -18px rgba(0,0,0,.7);}
  @media (prefers-color-scheme: dark){
    html:not([data-theme="light"]) .bw-head .ic{background:linear-gradient(160deg,#1b2a52,#23408e);}
    html:not([data-theme="light"]) .bw-card:hover{box-shadow:0 24px 50px -18px rgba(0,0,0,.7);}
  }

  @media (max-width:880px){ .bw-grid{grid-template-columns:1fr;} }
</style>
