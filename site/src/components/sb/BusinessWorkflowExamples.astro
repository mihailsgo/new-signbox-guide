---
import '../../styles/signbox-anim.css';
interface Props { class?: string; }
const { class: className = '' } = Astro.props;

// Real signing scenarios, grounded in a recognizable document per department.
// Roles + document types only - no invented people or companies. The node
// glyphs show the signing pattern; the copy makes it concrete.
const flows = [
  { dept: 'HR', doc: 'Employment contract', pattern: 'Single signer',
    desc: 'HR sends the agreement; the new hire signs with Smart-ID.', nodes: [
      { t: 'doc' }, { t: 'person', tone: 'blue' }, { t: 'done' },
  ]},
  { dept: 'Procurement', doc: 'Purchase order', pattern: 'External + internal',
    desc: 'A vendor signs externally, then Finance counter-signs.', nodes: [
      { t: 'doc' }, { t: 'person', tone: 'gold' }, { t: 'lock' }, { t: 'person', tone: 'blue' }, { t: 'done' },
  ]},
  { dept: 'Board', doc: 'Board resolution', pattern: 'Sequential approval',
    desc: 'Officers sign one after another in a fixed order.', nodes: [
      { t: 'doc' }, { t: 'num', n: 1 }, { t: 'num', n: 2 }, { t: 'num', n: 3 }, { t: 'done' },
  ]},
];

const icons = {
  doc: '<path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h5"/>',
  person: '<circle cx="12" cy="8" r="3.4"/><path d="M5.5 20c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5"/>',
  lock: '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>',
  done: '<path d="m5 13 4 4L19 7"/>',
};
---

<div class={`sb-anim bw ${className}`} aria-label="Abstract signing-pattern examples by department">
  <div class="bw-grid">
    {flows.map((f) => (
      <article class="bw-card">
        <header class="bw-head">
          <span class="bw-kicker">{f.dept} · {f.pattern}</span>
          <span class="bw-doc">{f.doc}</span>
          <span class="bw-desc">{f.desc}</span>
        </header>
        <div class="bw-flow" style={`--n:${f.nodes.length}`}>
          <span class="bw-rail" aria-hidden="true"></span>
          {f.nodes.map((nd, i) => (
            <span class={`bw-node t-${nd.t}${nd.tone ? ' tone-' + nd.tone : ''}`} style={`--i:${i}`}>
              {nd.t === 'num'
                ? <b>{nd.n}</b>
                : <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" set:html={icons[nd.t]} />}
            </span>
          ))}
        </div>
      </article>
    ))}
  </div>
</div>

<style>
  .bw{margin:0}
  .bw-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}
  .bw-card{position:relative;display:flex;flex-direction:column;gap:22px;min-width:0;padding:22px 20px;
    border:1px solid var(--sb-border-strong);border-radius:18px;background:var(--sb-card);box-shadow:var(--sb-shadow-sm);
    transition:transform .32s cubic-bezier(.22,1,.36,1),box-shadow .32s cubic-bezier(.22,1,.36,1),border-color .32s ease}
  .bw-card:hover{transform:translateY(-4px);border-color:color-mix(in srgb,var(--sb-gold) 42%,var(--sb-border));box-shadow:0 22px 42px -22px rgba(15,27,46,.42)}
  .bw-head{display:flex;flex-direction:column;gap:5px}
  .bw-kicker{color:var(--sb-gold);font-size:9px;font-weight:850;letter-spacing:.12em;text-transform:uppercase}
  .bw-doc{color:var(--sb-ink);font-size:15px;font-weight:800;letter-spacing:-.01em}
  .bw-desc{color:var(--sb-ink-soft);font-size:12.5px;line-height:1.45}

  .bw-flow{position:relative;display:flex;align-items:center;justify-content:space-between;gap:6px;padding:6px 2px 2px}
  .bw-rail{position:absolute;left:8%;right:8%;top:calc(50% - 4px);height:2px;border-radius:2px;background:var(--sb-border-strong);overflow:hidden}
  .bw-rail::after{content:"";position:absolute;inset:0;border-radius:2px;transform:scaleX(0);transform-origin:left;
    background:linear-gradient(90deg,var(--sb-blue),var(--sb-gold))}
  .bw-node{position:relative;z-index:1;width:36px;height:36px;flex:none;display:grid;place-items:center;border-radius:50%;
    border:2px solid color-mix(in srgb,var(--sb-blue) 45%,var(--sb-border));background:var(--sb-card);color:var(--sb-blue)}
  .bw-node svg{width:17px;height:17px}
  .bw-node b{font-size:13px;font-weight:850}
  .bw-node.tone-gold{border-color:color-mix(in srgb,var(--sb-gold) 50%,var(--sb-border));color:var(--sb-gold)}
  .bw-node.t-lock{border-color:var(--sb-border-strong);color:var(--sb-ink-soft);width:30px;height:30px}
  .bw-node.t-lock svg{width:14px;height:14px}
  .bw-node.t-done{border-color:color-mix(in srgb,var(--sb-success) 55%,var(--sb-border));background:var(--sb-success-soft);color:var(--sb-success)}
  .bw-node.t-done svg{stroke-width:2.6}

  @media (prefers-reduced-motion:no-preference){
    :global(.is-animating).bw .bw-rail::after{animation:bwFill 4.6s ease-in-out infinite}
    :global(.is-animating).bw .bw-node{animation:bwTravel 4.6s ease-in-out infinite;animation-delay:calc(var(--i) * .52s)}
    :global(.is-animating).bw .bw-node.t-done{animation:bwDone 4.6s ease-in-out infinite;animation-delay:calc(var(--i) * .52s)}
  }
  @keyframes bwFill{0%{transform:scaleX(0);opacity:1}10%{opacity:1}62%,88%{transform:scaleX(1);opacity:1}97%,100%{transform:scaleX(1);opacity:0}}
  @keyframes bwTravel{
    0%,6%{transform:scale(1)}
    11%,17%{transform:scale(1.18);box-shadow:0 0 0 4px color-mix(in srgb,var(--sb-gold) 16%,transparent);border-color:var(--sb-gold);color:var(--sb-gold)}
    26%,100%{transform:scale(1);box-shadow:none}
  }
  @keyframes bwDone{
    0%,6%{transform:scale(1)}
    11%,17%{transform:scale(1.2);box-shadow:0 0 0 5px color-mix(in srgb,var(--sb-success) 16%,transparent)}
    26%,100%{transform:scale(1);box-shadow:none}
  }

  @media (max-width:860px){.bw-grid{grid-template-columns:1fr}.bw-flow{max-width:340px}}
</style>

<script>
  function initBwAnimations() {
    document.querySelectorAll('.bw').forEach((el) => {
      if (el.hasAttribute('data-observed')) return;
      el.setAttribute('data-observed', 'true');
      const io = new IntersectionObserver(([e]) => el.classList.toggle('is-animating', e.isIntersecting), { threshold: 0.18 });
      io.observe(el);
    });
  }
  initBwAnimations();
  document.addEventListener('astro:after-swap', initBwAnimations);
</script>
