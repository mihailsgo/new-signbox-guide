---
/**
 * StatusLifecycle.astro — Draft → Started → Completed → Finished stepper.
 * A gold progress indicator fills through each status. "Completed" (people are
 * done) and "Finished" (container is ready) are intentionally distinct.
 * Theme-aware + reduced-motion safe (shows Finished active).
 */
import '../../styles/signbox-anim.css';
interface Props { class?: string; caption?: string; showCaption?: boolean; }
const {
  class: className = '',
  caption = 'Completed means every person is done. Finished means the final signed container has been generated — two distinct milestones, not the same thing.',
  showCaption = true,
} = Astro.props;
---
<figure class={`sb-anim status-lifecycle ${className}`} role="group" aria-label="Process status lifecycle: Draft, Started, Completed, Finished">
  <div class="sb-stage">
    <div class="sl" aria-hidden="true">
      <div class="sl-track">
        <div class="sl-rail"><div class="fill"></div></div>
        <div class="sl-step">
          <div class="sl-node n1"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/><path d="M14 3v5h5"/></svg></div>
          <div class="txt"><div class="nm">Draft</div><div class="ds">Process is prepared but not sent.</div></div>
        </div>
        <div class="sl-step">
          <div class="sl-node n2"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4l14 8-14 8z"/></svg></div>
          <div class="txt"><div class="nm">Started</div><div class="ds">Invitations are sent and actions are pending.</div></div>
        </div>
        <div class="sl-step">
          <div class="sl-node n3"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="3"/><circle cx="16" cy="8" r="3"/><path d="M2 20c0-3 2.7-5 6-5M22 20c0-3-2.7-5-6-5"/><path d="M9.5 17.5l1.8 1.8 3.2-3.6"/></svg></div>
          <div class="txt"><div class="nm">Completed</div><div class="ds">All required recipients have completed their actions.</div></div>
        </div>
        <div class="sl-step">
          <div class="sl-node n4 on"><div class="sl-final-glow"></div><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 3 6v6c0 5 3.8 8.4 9 10 5.2-1.6 9-5 9-10V6z"/><path d="M9 12l2 2 4-4"/></svg></div>
          <div class="txt"><div class="nm">Finished</div><div class="ds">Final signed container is generated and ready.</div></div>
        </div>
      </div>
    </div>
  </div>
  {showCaption && <figcaption class="sb-cap">{caption}</figcaption>}
</figure>

<style>
  .status-lifecycle{margin:0;display:flex;flex-direction:column;gap:14px;}
  .sb-cap{font-size:13.5px;line-height:1.5;color:var(--sb-ink-soft);max-width:62ch;}

  .sl{padding:8px 6px;}
  .sl-track{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative;}
  .sl-rail{position:absolute;top:27px;left:12.5%;right:12.5%;height:3px;border-radius:3px;background:var(--sb-border-strong);overflow:hidden;}
  .sl-rail .fill{position:absolute;inset:0;width:100%;background:linear-gradient(90deg,var(--sb-gold),var(--sb-gold-2));border-radius:3px;}
  .sl-step{display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center;position:relative;padding:0 8px;}
  .sl-node{width:54px;height:54px;border-radius:16px;display:grid;place-items:center;background:var(--sb-card);border:1px solid var(--sb-border-strong);color:var(--sb-muted);position:relative;z-index:1;}
  .sl-node svg{width:24px;height:24px;}
  .sl-node.on{color:#fff;background:linear-gradient(160deg,var(--sb-gold),var(--sb-gold-2));border-color:transparent;box-shadow:0 8px 20px -8px var(--sb-glow-gold);}
  .sl-step .nm{font-size:13px;font-weight:800;letter-spacing:-.01em;}
  .sl-step .ds{font-size:11.5px;color:var(--sb-ink-soft);line-height:1.35;max-width:160px;}
  .sl-final-glow{position:absolute;inset:-4px;border-radius:20px;box-shadow:0 0 0 0 var(--sb-glow-gold);pointer-events:none;}

  @media (max-width:680px){
    .sl-track{grid-template-columns:1fr;gap:14px;}
    .sl-rail{top:0;bottom:0;left:27px;right:auto;width:3px;height:auto;}
    .sl-rail .fill{width:100%;height:100%;background:linear-gradient(180deg,var(--sb-gold),var(--sb-gold-2));}
    .sl-step{flex-direction:row;text-align:left;gap:14px;}
    .sl-step .nm,.sl-step .ds{max-width:none;}
    .sl-step .txt{display:flex;flex-direction:column;gap:3px;}
  }

  @media (prefers-reduced-motion: no-preference){
    .sl-rail .fill{width:0;animation:slFill 6s ease-in-out infinite;}
    .sl-node.on{color:var(--sb-muted);background:var(--sb-card);border-color:var(--sb-border-strong);box-shadow:none;}
    .sl-node.n1{animation:slNode 6s ease-in-out infinite;animation-delay:-6s;}
    .sl-node.n2{animation:slNode 6s ease-in-out infinite;animation-delay:-4.8s;}
    .sl-node.n3{animation:slNode 6s ease-in-out infinite;animation-delay:-3.6s;}
    .sl-node.n4{animation:slNode 6s ease-in-out infinite;animation-delay:-2.4s;}
    .sl-final-glow{animation:slGlow 6s ease-in-out infinite;}
  }
  @keyframes slFill{0%,20%{width:0;}40%{width:33.33%;}60%{width:66.66%;}78%,100%{width:100%;}}
  @keyframes slNode{
    0%,3%{color:var(--sb-muted);background:var(--sb-card);border-color:var(--sb-border-strong);box-shadow:none;}
    8%,100%{color:#fff;background:linear-gradient(160deg,var(--sb-gold),var(--sb-gold-2));border-color:transparent;box-shadow:0 8px 20px -8px var(--sb-glow-gold);}
  }
  @keyframes slGlow{0%,66%{box-shadow:0 0 0 0 var(--sb-glow-gold);}74%{box-shadow:0 0 28px 3px var(--sb-glow-gold);}86%,100%{box-shadow:0 0 0 0 var(--sb-glow-gold);}}
  @media (max-width:680px) and (prefers-reduced-motion: no-preference){
    .sl-rail .fill{width:100%;height:0;}
    @keyframes slFill{0%,20%{height:0;}40%{height:33.33%;}60%{height:66.66%;}78%,100%{height:100%;}}
  }
</style>
