<style>
  /* Self-contained fixed-look illustration; strip the figure's default margins
     so the wrapper controls its own height. */
  .signbox-lifecycle { margin: 0; }
  /* The reference build relies on a global `* { box-sizing: border-box }`; the
     fixed 1360x940 frame and all its inline-padded children assume it. Scope
     that reset to the frame so the port matches 1:1 regardless of page resets. */
  .signbox-lifecycle :global(.sbl-wrap),
  .signbox-lifecycle :global(.sbl-frame),
  .signbox-lifecycle :global(.sbl-frame *) { box-sizing: border-box; }
</style>

<script>
  /* Driver - CSS does all the animating. This only fits the fixed-width design
     frame to its container width (transform: scale) and respects reduced motion.
     zoom/look/pace are hard-coded inline on .sbl-frame (Standard / Midnight
     glass / Standard 13s), so there is nothing else to wire. */
  const SBL_REF = 1360; // "Standard" reference width from the handoff.
  const SBL_FRAME_H = 940;

  function initSignboxLifecycle() {
    document.querySelectorAll<HTMLElement>('.signbox-lifecycle').forEach((fig) => {
      const wrap = fig.querySelector<HTMLElement>('.sbl-wrap');
      const frame = fig.querySelector<HTMLElement>('.sbl-frame');
      if (!wrap || !frame) return;

      const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) frame.style.setProperty('--pstate', 'paused');

      const fitScale = () => {
        frame.style.width = SBL_REF + 'px';
        const scale = (wrap.clientWidth || SBL_REF) / SBL_REF;
        frame.style.transform = 'scale(' + scale + ')';
        wrap.style.height = (SBL_FRAME_H * scale) + 'px';
      };

      // Re-init across view transitions without stacking observers.
      const prev = (fig as any).__sblRO as ResizeObserver | undefined;
      if (prev) prev.disconnect();
      const ro = new ResizeObserver(fitScale);
      ro.observe(wrap);
      (fig as any).__sblRO = ro;

      fitScale();
    });
  }

  initSignboxLifecycle();
  document.addEventListener('astro:page-load', initSignboxLifecycle);
  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll<HTMLElement>('.signbox-lifecycle').forEach((fig) => {
      const ro = (fig as any).__sblRO as ResizeObserver | undefined;
      if (ro) { ro.disconnect(); (fig as any).__sblRO = undefined; }
    });
  });
</script>
