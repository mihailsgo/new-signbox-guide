---
/**
 * StatusLifecycle - Draft -> Started -> Completed -> Finished.
 *
 * 1:1 port of the design handoff `signbox-lifecycle-reference.html`
 * (design_handoff_lifecycle_animation). One CSS variable (--cycle) drives the
 * whole loop; every keyframe is authored as a percentage of that cycle so all
 * elements stay in lockstep. Each of the four states occupies one quarter of
 * the loop: a single document visibly evolves (badge crossfades, DRAFT
 * watermark fades, signature draws itself, "All 3 parties signed" row appears,
 * VALID/QES seal stamps + container chips), with a synced process-timeline log.
 *
 * Defaults are hard-coded from the handoff: zoom "Standard" (ref 1360), look
 * "Midnight glass", pace "Standard" (13s) - all inline on .sbl-frame. The
 * demo's play/pause + zoom/look/pace <select> controls are intentionally
 * dropped; only fit-to-width scaling and reduced-motion are wired in JS.
 *
 * Fonts (Manrope / Space Grotesk / Space Mono) are already loaded globally in
 * Head.astro.
 *
 * Ambient keyframes are prefixed `lc*` (lcFloat/lcPulse/...) on purpose:
 * SignBoxHero.astro declares same-named global keyframes (sbFloat, sbPulse, ...)
 * and both render on the homepage, so unprefixed names would clobber each other.
 * This animation uses no avatar photos - nothing to swap.
 */
interface Props { class?: string; }
const { class: className = '' } = Astro.props;
---

<figure class={`sb-anim signbox-lifecycle ${className}`} role="group" aria-label="Process status lifecycle: Draft, Started, Completed, Finished">
<!-- WRAPPER (fluid) -> FRAME (fixed design, scaled to fit width) -->
<div class="sbl-wrap" style="width:100%; max-width:1280px; margin:0 auto; position:relative; overflow:hidden;">
<div class="sbl-frame" style="--cycle:13s; --pstate:running; --acc1:#3D7BFF; --acc2:#6AA1FF; --glow:61,123,255; --panel-bg:linear-gradient(165deg,#0c1326 0%,#0a0f1f 55%,#0b1024 100%); --panel-border:rgba(120,150,220,.14); --panel-bloom:radial-gradient(620px 320px at 25% -10%, rgba(61,123,255,.2), transparent 60%), radial-gradient(520px 320px at 100% 110%, rgba(45,210,126,.15), transparent 60%); --grid-op:.5; --grid-col:rgba(140,165,225,.05); width:1360px; height:940px; transform-origin:top left; background:radial-gradient(1200px 600px at 50% -10%, #eef2f9, #e1e7f1 60%, #d8dfeb); font-family:'Manrope',system-ui,sans-serif; color:#1B2436; padding:40px; display:flex; flex-direction:column; overflow:hidden;">

  <!-- HEADER -->
  <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:22px;">
    <div>
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
        <div style="width:9px; height:9px; border-radius:3px; background:linear-gradient(135deg,#3D7BFF,#6AA1FF);"></div>
        <span style="font-size:12.5px; font-weight:700; letter-spacing:1.6px; text-transform:uppercase; color:#6B7689;">TrustLynx SignBox · process lifecycle</span>
      </div>
      <h1 style="margin:0; font-family:'Space Grotesk',sans-serif; font-size:34px; font-weight:700; letter-spacing:-.5px; color:#141B2B;">From draft to a finished, valid document</h1>
    </div>
    <div style="display:flex; align-items:center; gap:14px; font-size:12.5px; font-weight:600; color:#5b6b85;">
      <span style="display:flex; align-items:center; gap:7px;"><span style="width:10px;height:10px;border-radius:3px;background:#8DA0C8;"></span>Draft</span>
      <span style="display:flex; align-items:center; gap:7px;"><span style="width:10px;height:10px;border-radius:3px;background:#3D7BFF;"></span>Started</span>
      <span style="display:flex; align-items:center; gap:7px;"><span style="width:10px;height:10px;border-radius:3px;background:#8B6BFF;"></span>Completed</span>
      <span style="display:flex; align-items:center; gap:7px;"><span style="width:10px;height:10px;border-radius:3px;background:#2DD27E;"></span>Finished</span>
    </div>
  </div>

  <!-- PANEL -->
  <div style="position:relative; flex:1; min-height:0; border-radius:22px; padding:30px 34px; display:flex; flex-direction:column; overflow:hidden; background:var(--panel-bg); border:1px solid var(--panel-border); box-shadow:0 30px 70px -30px rgba(10,16,36,.8), inset 0 1px 0 rgba(255,255,255,.05);">
    <div style="position:absolute; inset:0; pointer-events:none; background:var(--panel-bloom);"></div>
    <div style="position:absolute; inset:0; pointer-events:none; opacity:var(--grid-op); background-image:linear-gradient(var(--grid-col) 1px, transparent 1px), linear-gradient(90deg, var(--grid-col) 1px, transparent 1px); background-size:34px 34px;"></div>
    <div style="position:absolute; top:0; left:0; width:120px; height:100%; pointer-events:none; background:linear-gradient(90deg, transparent, rgba(255,255,255,.05), transparent); animation:lcSweep 8s ease-in-out infinite; animation-play-state:var(--pstate);"></div>
    <div class="ambient" style="position:absolute; inset:0; pointer-events:none;">
      <span style="position:absolute; left:14%; top:60%; width:4px; height:4px; border-radius:50%; background:#6AA1FF; animation:lcTwinkle 4s ease-in-out infinite; animation-play-state:var(--pstate);"></span>
      <span style="position:absolute; left:88%; top:30%; width:3px; height:3px; border-radius:50%; background:#9bd9b8; animation:lcTwinkle 5.5s ease-in-out infinite .6s; animation-play-state:var(--pstate);"></span>
      <span style="position:absolute; left:70%; top:78%; width:5px; height:5px; border-radius:50%; background:#6AA1FF; animation:lcDrift 9s linear infinite alternate; animation-play-state:var(--pstate);"></span>
      <span style="position:absolute; left:40%; top:86%; width:3px; height:3px; border-radius:50%; background:#cbd9ff; animation:lcTwinkle 6s ease-in-out infinite 1.2s; animation-play-state:var(--pstate);"></span>
    </div>

    <!-- LIFECYCLE RAIL -->
    <div style="position:relative; height:126px; flex:none;">
      <div style="position:relative; margin:0 70px; height:126px;">
        <div style="position:absolute; top:46px; left:0; right:0; height:4px; transform:translateY(-50%); background:rgba(255,255,255,.08); border-radius:99px;"></div>
        <div style="position:absolute; top:46px; left:0; height:4px; transform:translateY(-50%); border-radius:99px; background:linear-gradient(90deg,#8DA0C8,var(--acc1),#8B6BFF,#2DD27E); box-shadow:0 0 14px rgba(var(--glow),.5); width:4%; animation:lcFill var(--cycle) linear infinite; animation-play-state:var(--pstate);"></div>
        <div style="position:absolute; top:8px; left:0%; transform:translateX(-50%); z-index:4; animation:lcTravel var(--cycle) linear infinite; animation-play-state:var(--pstate);">
          <div style="width:30px; height:38px; border-radius:6px; background:linear-gradient(160deg,#ffffff,#dbe6ff); box-shadow:0 10px 22px rgba(var(--glow),.5), 0 0 0 1px rgba(255,255,255,.5); animation:lcFloat 3s ease-in-out infinite; animation-play-state:var(--pstate); position:relative;">
            <span style="position:absolute; top:7px; left:5px; right:5px; height:2px; background:#9bb4e8; border-radius:2px;"></span>
            <span style="position:absolute; top:13px; left:5px; right:9px; height:2px; background:#bcccf0; border-radius:2px;"></span>
            <span style="position:absolute; top:19px; left:5px; right:7px; height:2px; background:#bcccf0; border-radius:2px;"></span>
          </div>
        </div>
        <!-- node 1: Draft -->
        <div style="position:absolute; top:46px; left:0%; transform:translate(-50%,-50%); z-index:2;">
          <div style="position:absolute; inset:-6px; border-radius:50%; opacity:0; animation:act1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><div style="position:absolute; inset:0; border-radius:50%; border:1px solid rgba(141,160,200,.6); animation:lcPulse 2s ease-out infinite; animation-play-state:var(--pstate);"></div></div>
          <div style="position:relative; width:50px; height:50px; border-radius:50%; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); display:flex; align-items:center; justify-content:center; color:rgba(220,230,255,.4);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg></div>
          <div style="position:absolute; inset:0; border-radius:50%; background:linear-gradient(150deg,#8DA0C8,#6f82a8); display:flex; align-items:center; justify-content:center; color:#fff; opacity:0; box-shadow:0 12px 26px rgba(141,160,200,.4); animation:reach1 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"/></svg></div>
        </div>
        <div style="position:absolute; top:78px; left:0%; transform:translateX(-50%); white-space:nowrap; text-align:center;"><div style="font-size:13px; font-weight:700; color:#dfe7fb;">Draft</div><div style="font-size:10.5px; color:#8da0c8; margin-top:1px;">Prepared</div></div>
        <!-- node 2: Started -->
        <div style="position:absolute; top:46px; left:33.33%; transform:translate(-50%,-50%); z-index:2;">
          <div style="position:absolute; inset:-6px; border-radius:50%; opacity:0; animation:act2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><div style="position:absolute; inset:0; border-radius:50%; border:1px solid rgba(var(--glow),.7); animation:lcPulse 2s ease-out infinite; animation-play-state:var(--pstate);"></div></div>
          <div style="position:relative; width:50px; height:50px; border-radius:50%; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); display:flex; align-items:center; justify-content:center; color:rgba(220,230,255,.4);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/></svg></div>
          <div style="position:absolute; inset:0; border-radius:50%; background:linear-gradient(150deg,var(--acc1),var(--acc2)); display:flex; align-items:center; justify-content:center; color:#fff; opacity:0; box-shadow:0 12px 26px rgba(var(--glow),.45); animation:reach2 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4z"/></svg></div>
        </div>
        <div style="position:absolute; top:78px; left:33.33%; transform:translateX(-50%); white-space:nowrap; text-align:center;"><div style="font-size:13px; font-weight:700; color:#dfe7fb;">Started</div><div style="font-size:10.5px; color:#8da0c8; margin-top:1px;">Collecting signatures</div></div>
        <!-- node 3: Completed -->
        <div style="position:absolute; top:46px; left:66.66%; transform:translate(-50%,-50%); z-index:2;">
          <div style="position:absolute; inset:-6px; border-radius:50%; opacity:0; animation:act3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><div style="position:absolute; inset:0; border-radius:50%; border:1px solid rgba(139,107,255,.7); animation:lcPulse 2s ease-out infinite; animation-play-state:var(--pstate);"></div></div>
          <div style="position:relative; width:50px; height:50px; border-radius:50%; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); display:flex; align-items:center; justify-content:center; color:rgba(220,230,255,.4);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l4 4L13 8"/><path d="M11 16l3 3 7-9"/></svg></div>
          <div style="position:absolute; inset:0; border-radius:50%; background:linear-gradient(150deg,#8B6BFF,#b49bff); display:flex; align-items:center; justify-content:center; color:#fff; opacity:0; box-shadow:0 12px 26px rgba(139,107,255,.45); animation:reach3 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l4 4L13 8"/><path d="M11 16l3 3 7-9"/></svg></div>
        </div>
        <div style="position:absolute; top:78px; left:66.66%; transform:translateX(-50%); white-space:nowrap; text-align:center;"><div style="font-size:13px; font-weight:700; color:#dfe7fb;">Completed</div><div style="font-size:10.5px; color:#8da0c8; margin-top:1px;">All parties signed</div></div>
        <!-- node 4: Finished -->
        <div style="position:absolute; top:46px; left:100%; transform:translate(-50%,-50%); z-index:2;">
          <div style="position:absolute; inset:-6px; border-radius:50%; opacity:0; animation:act4 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><div style="position:absolute; inset:0; border-radius:50%; border:1px solid rgba(45,210,126,.7); animation:lcPulse 2s ease-out infinite; animation-play-state:var(--pstate);"></div></div>
          <div style="position:relative; width:50px; height:50px; border-radius:50%; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08); display:flex; align-items:center; justify-content:center; color:rgba(220,230,255,.4);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></div>
          <div style="position:absolute; inset:0; border-radius:50%; background:linear-gradient(150deg,#2DD27E,#1ea862); display:flex; align-items:center; justify-content:center; color:#fff; opacity:0; box-shadow:0 12px 26px rgba(45,210,126,.45); animation:reach4 var(--cycle) linear infinite; animation-play-state:var(--pstate);"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z"/><path d="M9 12l2 2 4-4"/></svg></div>
        </div>
        <div style="position:absolute; top:78px; left:100%; transform:translateX(-50%); white-space:nowrap; text-align:center;"><div style="font-size:13px; font-weight:700; color:#dfe7fb;">Finished</div><div style="font-size:10.5px; color:#8da0c8; margin-top:1px;">Sealed &amp; archived</div></div>
      </div>
    </div>

    <!-- BODY: document + event log -->
    <div style="position:relative; flex:1; min-height:0; display:flex; gap:38px; align-items:center; padding:8px 20px 0;">
      <!-- DOCUMENT -->
      <div style="flex:none; display:flex; flex-direction:column; align-items:center; gap:16px;">
        <div style="position:relative; width:280px; height:354px; border-radius:16px; background:linear-gradient(160deg,#ffffff,#eaf1fb); box-shadow:0 36px 70px -26px rgba(0,0,0,.7), 0 0 0 1px rgba(255,255,255,.4); padding:50px 24px 24px; animation:lcFloat 5s ease-in-out infinite; animation-play-state:var(--pstate); overflow:hidden;">
          <span style="position:absolute; top:0; right:0; border-width:0 26px 26px 0; border-style:solid; border-color:transparent #cdd9ee transparent transparent;"></span>
          <div style="position:absolute; inset:0; display:flex; align-items:center; justify-content:center; pointer-events:none; animation:bD var(--cycle) linear infinite; animation-play-state:var(--pstate);"><span style="font-family:'Space Grotesk',sans-serif; font-size:54px; font-weight:700; color:rgba(141,160,200,.16); transform:rotate(-22deg); letter-spacing:3px;">DRAFT</span></div>
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:16px;">
            <span style="font-family:'Space Grotesk',sans-serif; font-size:14px; font-weight:700; color:#1b2436;">Agreement.pdf</span>
            <span style="margin-left:auto; font-size:8px; font-weight:800; color:#fff; background:#3D7BFF; border-radius:3px; padding:3px 6px; letter-spacing:.3px;">PDF</span>
          </div>
          <span style="display:block; height:5px; border-radius:3px; background:#dde5f1; width:100%; margin-bottom:9px;"></span>
          <span style="display:block; height:5px; border-radius:3px; background:#dde5f1; width:94%; margin-bottom:9px;"></span>
          <span style="display:block; height:5px; border-radius:3px; background:#e6ecf6; width:78%; margin-bottom:9px;"></span>
          <span style="display:block; height:5px; border-radius:3px; background:#dde5f1; width:88%; margin-bottom:9px;"></span>
          <span style="display:block; height:5px; border-radius:3px; background:#e6ecf6; width:54%;"></span>
          <div style="position:absolute; left:24px; right:24px; bottom:58px;">
            <div style="font-size:8px; font-weight:800; letter-spacing:.5px; color:#9aa9c4; text-transform:uppercase;">Signed by · Legal · Finance · Director</div>
            <svg width="100%" height="40" viewBox="0 0 230 40" preserveAspectRatio="none" style="display:block; margin-top:2px; overflow:visible;"><path d="M4 30 C 12 9 20 8 23 27 C 25 37 33 33 38 22 C 44 9 52 9 56 27 C 59 39 68 33 76 22 C 86 8 96 35 108 24 C 120 13 130 31 144 18 C 156 9 166 28 180 16 C 192 9 204 24 214 14 C 220 10 224 18 226 13" stroke="#2f6bff" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="200" style="stroke-dashoffset:200; animation:docSig var(--cycle) linear infinite; animation-play-state:var(--pstate);"/></svg>
            <div style="border-top:1px solid #d6deec; margin-top:1px; padding-top:5px; display:flex; justify-content:space-between; font-size:8px; color:#9aa9c4; font-family:'Space Mono',monospace;"><span>Smart-ID · PIN2</span><span>2026-06-27</span></div>
          </div>
          <div style="position:absolute; left:24px; right:24px; bottom:20px; display:flex; align-items:center; gap:7px; padding:7px 11px; border-radius:9px; background:rgba(139,107,255,.1); border:1px solid rgba(139,107,255,.3); animation:compRow var(--cycle) linear infinite; animation-play-state:var(--pstate);">
            <span style="color:#8B6BFF; display:flex;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg></span>
            <span style="font-size:10px; font-weight:700; color:#5b4a9e;">All 3 parties signed</span>
          </div>
          <div style="position:absolute; top:16px; left:24px;">
            <span style="position:absolute; display:inline-flex; align-items:center; gap:5px; padding:4px 9px; border-radius:7px; font-size:10px; font-weight:800; letter-spacing:.4px; color:#5b6b85; background:#eef1f6; border:1px solid #dfe5ee; animation:bD var(--cycle) linear infinite; animation-play-state:var(--pstate);"><span style="width:6px;height:6px;border-radius:50%;background:#8DA0C8;"></span>DRAFT</span>
            <span style="position:absolute; display:inline-flex; align-items:center; gap:5px; padding:4px 9px; border-radius:7px; font-size:10px; font-weight:800; letter-spacing:.4px; color:#fff; background:linear-gradient(150deg,#3D7BFF,#6AA1FF); animation:bS var(--cycle) linear infinite; animation-play-state:var(--pstate);"><span style="width:6px;height:6px;border-radius:50%;background:#fff;"></span>IN PROGRESS</span>
            <span style="position:absolute; display:inline-flex; align-items:center; gap:5px; padding:4px 9px; border-radius:7px; font-size:10px; font-weight:800; letter-spacing:.4px; color:#fff; background:linear-gradient(150deg,#8B6BFF,#b49bff); animation:bC var(--cycle) linear infinite; animation-play-state:var(--pstate);"><span style="width:6px;height:6px;border-radius:50%;background:#fff;"></span>COMPLETED</span>
            <span style="position:absolute; display:inline-flex; align-items:center; gap:5px; padding:4px 9px; border-radius:7px; font-size:10px; font-weight:800; letter-spacing:.4px; color:#fff; background:linear-gradient(150deg,#2DD27E,#1ea862); animation:bF var(--cycle) linear infinite; animation-play-state:var(--pstate);"><span style="width:6px;height:6px;border-radius:50%;background:#fff;"></span>FINISHED</span>
          </div>
          <div style="position:absolute; top:46px; right:-6px; animation:sealStamp var(--cycle) linear infinite; animation-play-state:var(--pstate);">
            <div style="width:92px; height:92px; border-radius:50%; background:linear-gradient(150deg,#2DD27E,#1ea862); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:1px; box-shadow:0 0 0 5px rgba(45,210,126,.2), 0 18px 36px rgba(45,210,126,.5), inset 0 2px 6px rgba(255,255,255,.35); border:2px solid rgba(255,255,255,.5);">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l4 4 10-10"/></svg>
              <span style="color:#fff; font-family:'Space Grotesk',sans-serif; font-size:12px; font-weight:700; letter-spacing:1px;">VALID</span>
              <span style="color:#d6ffe7; font-size:7.5px; font-weight:700; letter-spacing:.4px;">QES · eIDAS</span>
            </div>
          </div>
        </div>
        <div style="display:flex; gap:8px; animation:chipsIn var(--cycle) linear infinite; animation-play-state:var(--pstate);">
          <span style="font-family:'Space Mono',monospace; font-size:10.5px; color:#bcd0ff; background:rgba(61,123,255,.14); border:1px solid rgba(120,160,255,.28); padding:4px 9px; border-radius:6px;">ASiC-E</span>
          <span style="font-family:'Space Mono',monospace; font-size:10.5px; color:#bcd0ff; background:rgba(61,123,255,.14); border:1px solid rgba(120,160,255,.28); padding:4px 9px; border-radius:6px;">XAdES-LT</span>
          <span style="font-family:'Space Mono',monospace; font-size:10.5px; color:#8ff0bd; background:rgba(45,210,126,.14); border:1px solid rgba(45,210,126,.32); padding:4px 9px; border-radius:6px;">QES</span>
        </div>
      </div>
      <!-- EVENT LOG -->
      <div style="flex:1; min-width:0; max-width:480px; padding:22px 24px; border-radius:18px; background:linear-gradient(160deg, rgba(255,255,255,.05), rgba(255,255,255,.015)); border:1px solid rgba(140,165,225,.14);">
        <div style="font-size:11px; font-weight:800; letter-spacing:1.2px; text-transform:uppercase; color:#8da0c8; margin-bottom:18px;">Process timeline</div>
        <div style="position:relative; display:flex; flex-direction:column; gap:16px;">
          <div style="position:absolute; left:13px; top:6px; bottom:6px; width:2px; background:rgba(140,165,225,.16);"></div>
          <div style="position:relative; display:flex; gap:14px; align-items:flex-start; animation:log1 var(--cycle) linear infinite; animation-play-state:var(--pstate);">
