---
/**
 * Home.astro - TrustLynx SignBox product-story landing.
 * Rendered inside Starlight's `splash` template (Starlight provides the
 * header, nav, search, theme toggle and <head>). Composes the animated
 * explainer components into a business-level product story above the guide.
 * Styles are scoped + namespaced under `.sb-home`; theming follows
 * Starlight's html[data-theme]; all motion respects prefers-reduced-motion.
 */
import SignBoxHero from './SignBoxHero.astro';
import PortalSplitAnimation from './PortalSplitAnimation.astro';
import SigningModesAnimation from './SigningModesAnimation.astro';
import StatusLifecycle from './StatusLifecycle.astro';
import ValidContainerAnimation from './ValidContainerAnimation.astro';
import BusinessWorkflowExamples from './BusinessWorkflowExamples.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const u = (slug) => `${base}/${slug}/`;

// Intent-based entry router: the four ways people arrive at SignBox.
// First card is the "just looking" path -> the product overview / before-you-start.
const paths = [
  {
    t: 'I want to understand SignBox',
    d: 'See what SignBox is, the two-portal model and what you need before you start.',
    href: u('before-you-start'),
    cta: 'View product overview',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  },
  {
    t: 'I need to create a signing process',
    d: 'Upload a document, add recipients and roles, choose a signing mode, then start and track.',
    href: u('initiating'),
    cta: 'Open initiator guide',
    icon: '<rect x="3" y="4" width="18" height="14" rx="2"/><path d="M3 9h18M8 21h8"/>',
  },
  {
    t: 'I received a signing invitation',
    d: 'Open the secure link, authenticate with Smart-ID / e-ID and sign - no account required.',
    href: u('signing'),
    cta: 'Open signer guide',
    icon: '<rect x="6" y="2.5" width="12" height="19" rx="3"/><path d="M10 18.5h4"/>',
  },
  {
    t: 'I manage templates, profiles & settings',
    d: 'Configure document profiles, attributes, contacts and templates for the whole organization.',
    href: u('management'),
    cta: 'Open admin guide',
    icon: '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.6 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.6a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
  },
];

// Plain-language walkthrough of a single, recognizable scenario. Roles only -
// no invented people or companies (per the product's anti-reference rules).
const hrSteps = [
  'HR uploads the employment agreement.',
  'The new hire gets a secure signing link by email - no account needed.',
  'They confirm their identity and sign on their phone with Smart-ID.',
  'HR sees the status update automatically.',
  'The final signed file is stored and independently verifiable.',
];

const benefits = [
  {
    t: 'End-to-end process control',
    d: 'Follow every process through Draft, Started, Completed and Finished - nothing slips through the cracks.',
    href: u('tracking'),
    icon: '<path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
  },
  {
    t: 'Trusted signing',
    d: 'Smart-ID, Mobile-ID, eParaksts, ID card and country-specific methods - backed by national identity providers.',
    href: u('appendix'),
    icon: '<rect x="6" y="2.5" width="12" height="19" rx="3"/><path d="M10 18.5h4"/>',
  },
  {
    t: 'Reusable workflows',
    d: 'Save templates, contacts and document profiles so recurring processes start in seconds.',
    href: u('templates-contacts'),
    icon: '<rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/>',
  },
  {
    t: 'Audit-ready result',
    d: 'An ASiC-E container with QES and XAdES-LT signatures and built-in validation - verifiable long after signing.',
    href: u('signing'),
    icon: '<path d="M12 2 4 5v6c0 4.5 3.3 7.6 8 9 4.7-1.4 8-4.5 8-9V5z"/><path d="M9 12l2 2 4-4"/>',
  },
];

const roles = [
  { t: 'Signer', d: 'Applies a legally valid signature.', cls: 'gold' },
  { t: 'Approver', d: 'Approves the process without signing.', cls: 'blue' },
  { t: 'Viewer', d: 'Can only view the document.', cls: 'muted' },
];

const docs = [
  { t: 'Before you start', d: 'Concepts, the two portals and prerequisites.', href: u('before-you-start') },
  { t: 'Initiating a signing process', d: 'Upload, add recipients, choose a signing mode.', href: u('initiating') },
  { t: 'Signing with Smart-ID', d: 'Authenticate and sign on the external portal.', href: u('signing') },
  { t: 'Tracking & status', d: 'Follow a process from draft to finished container.', href: u('tracking') },
];

// in-page section navigation (sticky, sits under Starlight's header)
const navLinks = [
  { id: 'how', t: 'How it works' },
  { id: 'portals', t: 'Portals' },
  { id: 'modes', t: 'Signing modes' },
  { id: 'why', t: 'Why SignBox' },
  { id: 'result', t: 'Result' },
  { id: 'docs', t: 'Docs' },
  { id: 'faq', t: 'FAQ' },
];

// e-ID + signature-standard icon chips
const phoneIcon = '<rect x="6" y="2.5" width="12" height="19" rx="3"/><path d="M10 18.5h4"/>';
const cardIcon = '<rect x="2.5" y="5" width="19" height="14" rx="2.5"/><circle cx="8" cy="11" r="2"/><path d="M13 9h6M13 13h6M5 16h8"/>';
const penIcon = '<path d="M12 19l7-7a2.1 2.1 0 0 0-3-3l-7 7-1 4z"/><path d="M5 21h14"/>';
const sealIcon = '<path d="M12 2 4 5v6c0 4.5 3.3 7.6 8 9 4.7-1.4 8-4.5 8-9V5z"/><path d="M9 12l2 2 4-4"/>';
const methods = [
  { t: 'Smart-ID', k: 'e-ID', icon: phoneIcon },
  { t: 'Mobile-ID', k: 'e-ID', icon: phoneIcon },
  { t: 'eParaksts', k: 'e-ID', icon: penIcon },
  { t: 'ID card', k: 'e-ID', icon: cardIcon },
  { t: 'QES', k: 'standard', icon: sealIcon },
  { t: 'XAdES-LT', k: 'standard', icon: sealIcon },
  { t: 'ASiC-E', k: 'container', icon: sealIcon },
];

const faqs = [
  { q: 'Are SignBox signatures legally valid?', a: 'Yes. SignBox produces qualified electronic signatures (QES) in a XAdES-LT, long-term-validatable ASiC-E container - the highest assurance level under eIDAS, with built-in validation.' },
  { q: 'What does signing look like for the person I invite?', a: 'They open the secure link, choose an e-ID method, confirm their identity and sign - usually in under a minute. No account, and nothing to install.' },
  { q: 'What do I get at the end?', a: 'A single signed file: an ASiC-E container holding the original document, every signature, trusted timestamps and validation data. You can download it and verify it independently.' },
  { q: 'Can the signed file be verified later, outside SignBox?', a: 'Yes. The container is a standard eIDAS format any compliant validator can check, with embedded long-term validation data that keeps it verifiable for years.' },
  { q: 'Which e-ID methods are supported?', a: 'Smart-ID, Mobile-ID, eParaksts and national ID cards, with country-specific methods selected by the signer on the external portal.' },
  { q: 'Do external signers need an account?', a: 'No. A signer opens a secure invitation link, authenticates with their e-ID and signs - no SignBox account required.' },
  { q: 'What is the difference between Completed and Finished?', a: 'Completed means every recipient has acted. Finished means the final signed document has been generated and the process is closed - two distinct milestones.' },
  { q: 'Can I reuse a recurring signing setup?', a: 'Yes - save templates, contacts and document profiles so a recurring process starts pre-filled in seconds.' },
];
---

<div class="sb-home">
  <!-- ============ HERO ============ -->
  <header class="sb-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-copy">
      <span class="eyebrow">TrustLynx SignBox · e-signing platform</span>
      <h1>Legally valid e-signing for business documents</h1>
      <p>Upload a document, invite signers, collect trusted e-ID signatures, and receive a verifiable signed file ready for audit.</p>
      <div class="hero-cta">
        <a class="btn primary" href="mailto:sales@trustlynx.io?subject=SignBox%20demo%20request">Request a demo</a>
        <a class="btn secondary" href="mailto:sales@trustlynx.io?subject=SignBox%20enquiry">Contact TrustLynx</a>
        <a class="btn text" href="#how">See how it works <span aria-hidden="true">↓</span></a>
      </div>
      <p class="hero-tech"><strong>For technical &amp; legal teams:</strong> SignBox produces ASiC-E / eDoc containers with QES, XAdES-LT and embedded validation data.</p>
      <p class="hero-segments">Built for HR, legal, procurement, finance, public sector, and enterprise document workflows.</p>
    </div>
    <div class="hero-art">
      <SignBoxHero />
    </div>
    <div class="band">
      <span class="band-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
      <p><strong>When to use SignBox.</strong> When your organization needs legally valid electronic signing, multiple signers, national e-ID methods, and a final validated container.</p>
    </div>
  </header>

  <!-- ============ CHOOSE YOUR PATH (intent router) ============ -->
  <section class="sec path-sec" aria-labelledby="path-h">
    <div class="sec-head">
      <h2 id="path-h">Where do you want to start?</h2>
      <p>Pick the path that matches what you need to do.</p>
    </div>
    <div class="path-grid">
      {paths.map((p) => (
        <a class="path-card" href={p.href}>
          <span class="path-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} /></span>
          <h3>{p.t}</h3>
          <p>{p.d}</p>
          <span class="path-cta">{p.cta}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
      ))}
    </div>
  </section>

  <!-- ============ STICKY SECTION NAV ============ -->
  <nav class="sb-subnav" aria-label="Page sections">
    {navLinks.map((l) => <a href={`#${l.id}`}>{l.t}</a>)}
  </nav>

  <!-- ============ HOW SIGNBOX WORKS ============ -->
  <section id="how" class="sec story-sec">
    <div class="sec-head">
      <h2>How SignBox works</h2>
      <p>One document, one workflow - follow it from draft to a sealed, validated signed document.</p>
    </div>
    <div class="hr-walk">
      <span class="hr-walk-kicker">Example · hiring a new employee</span>
      <ol class="hr-walk-steps">
        {hrSteps.map((s, i) => (
          <li><span class="hr-step-n">{i + 1}</span><span>{s}</span></li>
        ))}
      </ol>
    </div>
    <StatusLifecycle class="how-visual" />
  </section>

  <!-- ============ INTERNAL & EXTERNAL PORTALS ============ -->
  <section id="portals" class="sec story-sec">
    <div class="sec-head">
      <h2>Internal &amp; external portals</h2>
      <p>Initiators build and track processes in the internal portal; signers act externally through a secure handoff - no account required.</p>
    </div>
    <PortalSplitAnimation />
    <div class="role-grid">
      {roles.map((r) => (
        <div class={`role-card ${r.cls}`}>
          <span class="role-dot"></span>
          <div><h3>{r.t}</h3><p>{r.d}</p></div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ PARALLEL OR SEQUENTIAL SIGNING ============ -->
  <section id="modes" class="sec story-sec">
    <div class="sec-head">
      <h2>Parallel or sequential signing</h2>
      <p>Send to everyone at once, or enforce a strict signing order group by group.</p>
    </div>
    <SigningModesAnimation class="how-visual" />
  </section>

  <!-- ============ WHY ORGANIZATIONS USE IT ============ -->
  <section id="why" class="sec story-sec">
    <div class="sec-head">
      <h2>Why organizations use it</h2>
      <p>The reasons teams standardize on SignBox for organization-wide signing.</p>
    </div>
    <div class="ben-grid">
      {benefits.map((b) => (
        <a class="ben-card" href={b.href}>
          <span class="ben-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={b.icon} /></span>
          <h3>{b.t}</h3>
          <p>{b.d}</p>
        </a>
      ))}
    </div>
    <div class="secondary-block bw-block">
      <div class="support-copy">
        <h3 class="subhead">Real business workflows</h3>
        <p>How teams put SignBox to work day to day - from a single-signer contract to multi-party approval.</p>
      </div>
      <BusinessWorkflowExamples />
    </div>
  </section>

  <!-- ============ TRUST / LEGAL RESULT ============ -->
  <section id="result" class="sec trust-sec">
    <div class="sec-head">
      <h2>A signed file you can trust - and prove</h2>
      <p>Every signature is independently verifiable and tamper-evident, and the file stays valid for years - no special software needed to check it. Here is what is inside.</p>
    </div>
    <ValidContainerAnimation class="how-visual" />
    <div class="method-strip">
      {methods.map((m) => (
        <span class={`method-chip ${m.k}`}>
          <span class="method-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={m.icon} /></span>
          {m.t}
        </span>
      ))}
    </div>
  </section>

  <!-- ============ DOCUMENTATION ENTRY ============ -->
  <section id="docs" class="sec docs-sec">
    <div class="sec-head">
      <h2>Read the documentation</h2>
      <p>Jump straight to the pages that matter most.</p>
    </div>
    <div class="doc-grid">
      {docs.map((d) => (
        <a class="doc-card" href={d.href}>
          <div class="doc-tx"><h3>{d.t}</h3><p>{d.d}</p></div>
          <span class="doc-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
        </a>
      ))}
    </div>
    <div id="faq" class="secondary-block faq-block">
      <div class="support-copy">
        <h3 class="subhead">Frequently asked questions</h3>
        <p>The essentials for evaluating SignBox - including what signing feels like and what you get at the end.</p>
      </div>
      <div class="faq">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary><span class="faq-q">{f.q}</span><span class="faq-mark"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg></span></summary>
            <div class="faq-answer"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
    <div class="cta">
      <div class="cta-inner">
        <span class="cta-eyebrow">Get started with TrustLynx</span>
        <h2>Bring legally valid e-signing to your organization</h2>
        <p>Talk to our team about rolling out SignBox, or explore the developer resources.</p>
        <div class="cta-actions">
          <a class="btn primary lg" href="mailto:sales@trustlynx.io?subject=SignBox%20demo%20request">Request a demo</a>
          <a class="btn ghost lg" href="mailto:sales@trustlynx.io?subject=SignBox%20enquiry">Contact TrustLynx</a>
          <a class="btn link" href="https://developer.trustlynx.com/" target="_blank" rel="noopener noreferrer">Developer portal<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></a>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .sb-home{
    --hp-ink:var(--sl-color-white);
    --hp-ink-soft:var(--sl-color-gray-2);
    --hp-surface:var(--sl-color-gray-7,#f6f7f9);
    --hp-border:var(--sl-color-gray-5);
    --hp-gold:#b58635; --hp-gold-2:#d8a84e; --hp-eyebrow:#8a6519; --hp-blue:#2f6bff;
    --hp-navy:#17243b;
    max-width:1180px;margin-inline:auto;overflow-x:clip;
  }
  :global([data-theme="dark"]) .sb-home{
    --hp-surface:#0f1626; --hp-gold:#d8a84e; --hp-eyebrow:#d8a84e; --hp-blue:#5b8bff;
  }
  .sb-home :where(h1,h2,h3,p){margin:0;}

  /* The hero is a product stage, not an article introduction. */
  .sb-hero{position:relative;display:flex;flex-direction:column;align-items:center;text-align:center;gap:24px;padding:clamp(30px,4vw,48px) 0 clamp(58px,7vw,82px);}
  .hero-glow{position:absolute;inset:-110px -24% auto;height:660px;pointer-events:none;z-index:0;
    background:radial-gradient(44% 54% at 50% 12%,color-mix(in srgb,var(--hp-gold) 24%,transparent),transparent 78%);}
  .hero-copy,.hero-art{position:relative;z-index:1;}
  .hero-copy{max-width:64rem;margin-inline:auto;}
  .hero-art{width:100%;filter:drop-shadow(0 28px 54px color-mix(in srgb,var(--hp-navy) 18%,transparent));}
  .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--hp-eyebrow);margin-bottom:18px;padding:6px 14px;border-radius:999px;border:1px solid color-mix(in srgb,var(--hp-gold) 35%,var(--hp-border));background:color-mix(in srgb,var(--hp-gold) 9%,transparent);}
  .hero-copy h1{font-size:clamp(38px,5.2vw,61px);line-height:.99;letter-spacing:-.045em;font-weight:800;text-wrap:balance;margin-bottom:18px;}
  .hero-copy p{font-size:clamp(16px,1.5vw,18px);line-height:1.55;color:var(--hp-ink-soft);max-width:58ch;margin:0 auto 22px;}
  .hero-cta{display:flex;gap:10px;flex-wrap:wrap;justify-content:center;align-items:center;}
  .hero-copy .hero-tech{margin:16px auto 0;font-size:13px;line-height:1.5;max-width:72ch;color:var(--hp-ink-soft);opacity:.92;}
  .hero-copy .hero-tech strong{color:var(--hp-ink);font-weight:750;}
  .hero-segments{margin:10px auto 0!important;font-size:13px!important;font-weight:650;letter-spacing:.015em;color:var(--hp-ink-soft);opacity:.88;max-width:66ch!important;}

  .btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;min-height:48px;font-size:15px;font-weight:750;text-decoration:none;padding:12px 23px;border-radius:10px;transition:transform .24s cubic-bezier(.22,1,.36,1),border-color .24s ease,box-shadow .24s ease,background-color .24s ease;border:1px solid transparent;cursor:pointer;}
  .btn.primary{background:linear-gradient(160deg,var(--hp-gold-2),var(--hp-gold));color:#241a07;box-shadow:0 10px 26px -12px rgba(181,134,53,.7);}
  .btn.primary:hover{transform:translateY(-2px);}
  .btn.secondary,.btn.ghost{background:color-mix(in srgb,var(--hp-surface) 88%,transparent);color:var(--hp-ink);border-color:var(--hp-border);}
  .btn.secondary:hover,.btn.ghost:hover{border-color:var(--hp-gold);transform:translateY(-2px);}
  .btn.text{padding-inline:12px;color:var(--hp-ink-soft);background:transparent;}
  .btn.text:hover{color:var(--hp-ink);transform:translateY(-2px);}

  /* when-to-use band */
  .band{display:flex;gap:12px;align-items:center;max-width:820px;padding:12px 18px;border-radius:999px;
    border:1px solid color-mix(in srgb,var(--hp-gold) 26%,var(--hp-border));
    background:color-mix(in srgb,var(--hp-gold) 5%,transparent);}
  .band-ic{flex:none;width:28px;height:28px;border-radius:999px;display:grid;place-items:center;color:var(--hp-gold);background:color-mix(in srgb,var(--hp-gold) 12%,transparent);}
  .band-ic svg{width:15px;height:15px;}
  .band p{font-size:13.5px;line-height:1.45;color:var(--hp-ink-soft);text-align:left;}
  .band strong{color:var(--hp-ink);}

  /* sections */
  .sec{padding:clamp(38px,5vw,60px) 0;border-top:1px solid var(--hp-border);}
  .sec[id]{scroll-margin-top:calc(var(--sl-nav-height,4rem) + 58px);}
  #faq{scroll-margin-top:calc(var(--sl-nav-height,4rem) + 58px);}
  .sec-head{margin-bottom:clamp(24px,3vw,34px);max-width:64ch;}
  .sec-head h2{font-size:clamp(29px,3.8vw,43px);line-height:1.05;letter-spacing:-.035em;font-weight:800;margin-bottom:12px;text-wrap:balance;}
  .sec-head h3.subhead{font-size:clamp(17px,2.1vw,21px);letter-spacing:-.01em;font-weight:800;margin:0 0 6px;color:var(--hp-ink);}
  .sec-head p{font-size:16px;line-height:1.6;color:var(--hp-ink-soft);}
  .sec-head em{font-style:normal;color:var(--hp-gold);font-weight:700;}

  /* how-it-works lead visual (process-lifecycle animation) */
  :global(.how-visual){margin-top:8px;}

  /* sticky in-page section nav (pins under Starlight's header) */
  .sb-subnav{position:sticky;top:var(--sl-nav-height,4rem);z-index:20;display:flex;gap:2px;justify-content:center;flex-wrap:nowrap;overflow-x:auto;padding:8px 4px;
    background:color-mix(in srgb,var(--sl-color-bg,#fff) 90%,transparent);backdrop-filter:saturate(140%) blur(10px);border-bottom:1px solid var(--hp-border);scrollbar-width:none;}
  .sb-subnav::-webkit-scrollbar{display:none;}
  .sb-subnav a{flex:none;padding:7px 13px;border-radius:999px;font-size:13px;font-weight:700;color:var(--hp-ink-soft);text-decoration:none;white-space:nowrap;transition:color .2s ease,background-color .2s ease;}
  .sb-subnav a:hover{color:var(--hp-ink);background:color-mix(in srgb,var(--hp-gold) 9%,transparent);}
  .sb-subnav a[aria-current="true"]{color:var(--hp-gold);background:color-mix(in srgb,var(--hp-gold) 13%,transparent);}

  /* choose-your-path intent router */
  .path-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
  .path-card{display:grid;grid-template-rows:auto auto 1fr auto;gap:10px;padding:22px 22px 20px;border:1px solid var(--hp-border);border-radius:16px;
    background:color-mix(in srgb,var(--hp-surface) 64%,transparent);text-decoration:none;color:inherit;
    transition:transform .25s cubic-bezier(.22,1,.36,1),border-color .25s ease,box-shadow .25s ease;}
  .path-card:hover{transform:translateY(-3px);border-color:color-mix(in srgb,var(--hp-gold) 42%,var(--hp-border));box-shadow:0 18px 36px -24px rgba(15,27,46,.5);}
  .path-ic{width:42px;height:42px;border-radius:11px;display:grid;place-items:center;color:var(--hp-blue);background:color-mix(in srgb,var(--hp-blue) 10%,transparent);}
  .path-ic svg{width:22px;height:22px;}
  .path-card h3{font-size:17px;letter-spacing:-.01em;line-height:1.22;}
  .path-card>p{font-size:13.5px;color:var(--hp-ink-soft);line-height:1.5;}
  .path-cta{display:inline-flex;align-items:center;gap:6px;font-size:13.5px;font-weight:750;color:var(--hp-gold);}
  .path-cta svg{width:15px;height:15px;transition:transform .25s ease;}
  .path-card:hover .path-cta svg{transform:translateX(4px);}

  /* plain-language scenario walkthrough (leads "How SignBox works") */
  .hr-walk{margin-bottom:clamp(20px,3vw,30px);padding:20px 22px;border:1px solid var(--hp-border);border-radius:16px;background:color-mix(in srgb,var(--hp-surface) 58%,transparent);}
  .hr-walk-kicker{display:inline-block;font-size:11px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--hp-eyebrow);margin-bottom:16px;}
  .hr-walk-steps{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(5,1fr);gap:16px;}
  /* Override brand.css's global "ol > li" gold-stepper. Astro scopes styles with
     :where() (zero specificity), so we lead with the .hr-walk ancestor class to
     out-specify brand's .sl-markdown-content ol>li rules. This list draws its own
     .hr-step-n badge, so suppress the injected counter circle and its indent. */
  .hr-walk .hr-walk-steps li{display:flex;flex-direction:column;gap:9px;margin:0;padding:0;font-size:13.5px;line-height:1.45;color:var(--hp-ink-soft);}
  .hr-walk .hr-walk-steps li::before{content:none;display:none;}
  .hr-step-n{width:27px;height:27px;border-radius:999px;display:grid;place-items:center;font-size:13px;font-weight:800;color:var(--hp-gold);background:color-mix(in srgb,var(--hp-gold) 13%,transparent);}

  .secondary-block{margin-top:22px;padding:24px;border:1px solid var(--hp-border);border-radius:18px;background:color-mix(in srgb,var(--hp-surface) 64%,transparent);}
  .support-copy{margin-bottom:20px;}
  .support-copy .subhead{font-size:19px;letter-spacing:-.015em;margin-bottom:6px;}
  .support-copy p{font-size:14px;line-height:1.55;color:var(--hp-ink-soft);}
  .support-copy em{font-style:normal;color:var(--hp-gold);font-weight:700;}

  /* roles (sit under the portals animation) */
  .role-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:18px;border-block:1px solid var(--hp-border);}
  .role-card{display:flex;gap:12px;align-items:flex-start;padding:18px;}
  .role-card:not(:last-child){border-inline-end:1px solid var(--hp-border);}
  .role-card h3{font-size:15px;margin-bottom:2px;}
  .role-card p{font-size:13px;color:var(--hp-ink-soft);}
  .role-dot{width:11px;height:11px;border-radius:999px;flex:none;margin-top:5px;}
  .role-card.gold .role-dot{background:var(--hp-gold);}
  .role-card.blue .role-dot{background:var(--hp-blue);}
  .role-card.muted .role-dot{background:var(--hp-ink-soft);}

  /* benefits */
  .ben-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0;border-block:1px solid var(--hp-border);}
  .ben-card{display:grid;grid-template-columns:42px 1fr;grid-template-rows:auto auto;gap:8px 16px;padding:25px 24px;text-decoration:none;color:inherit;transition:background-color .25s ease;}
  .ben-card:nth-child(odd){border-inline-end:1px solid var(--hp-border);}
  .ben-card:nth-child(-n+2){border-bottom:1px solid var(--hp-border);}
  .ben-card:hover{background:color-mix(in srgb,var(--hp-gold) 5%,transparent);}
  /* icon spans both rows and pins to the top so its top edge lines up with
     the heading's top edge (text beginning), not its baseline. */
  .ben-ic{grid-column:1;grid-row:1/3;align-self:start;width:40px;height:40px;border-radius:11px;display:grid;place-items:center;color:var(--hp-gold);background:color-mix(in srgb,var(--hp-gold) 12%,transparent);}
  .ben-ic svg{width:21px;height:21px;}
  .ben-card h3{grid-column:2;grid-row:1;align-self:start;font-size:16px;letter-spacing:-.01em;line-height:1.25;}
  .ben-card p{grid-column:2;grid-row:2;font-size:14px;color:var(--hp-ink-soft);line-height:1.55;}

  /* doc cards */
  .doc-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0;border-block:1px solid var(--hp-border);}
  .doc-card{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:22px;text-decoration:none;color:inherit;transition:background-color .25s ease;}
  .doc-card:nth-child(odd){border-inline-end:1px solid var(--hp-border);}
  .doc-card:nth-child(-n+2){border-bottom:1px solid var(--hp-border);}
  .doc-card:hover{background:color-mix(in srgb,var(--hp-gold) 5%,transparent);}
  .doc-tx h3{font-size:16px;margin-bottom:3px;letter-spacing:-.01em;}
  .doc-tx p{font-size:13.5px;color:var(--hp-ink-soft);}
  .doc-arrow{width:34px;height:34px;flex:none;border-radius:10px;display:grid;place-items:center;color:var(--hp-gold);background:color-mix(in srgb,var(--hp-gold) 12%,transparent);}
  .doc-arrow svg{width:17px;height:17px;transition:transform .25s ease;}
  .doc-card:hover .doc-arrow{transform:translateX(4px);}

  .trust-sec{position:relative;}

  /* methods strip (sits under the trust-layer animation) */
  .method-strip{display:flex;flex-wrap:wrap;gap:10px;justify-content:center;margin-top:26px;}
  .method-chip{display:inline-flex;align-items:center;gap:8px;font-size:13px;font-weight:700;padding:8px 13px 8px 9px;border-radius:999px;background:var(--hp-surface);border:1px solid var(--hp-border);}
  .method-ic{width:26px;height:26px;border-radius:8px;display:grid;place-items:center;flex:none;}
  .method-ic svg{width:16px;height:16px;}
  .method-chip.e-ID .method-ic{color:var(--hp-blue);background:color-mix(in srgb,var(--hp-blue) 12%,transparent);}
  .method-chip.standard .method-ic,.method-chip.container .method-ic{color:var(--hp-gold);background:color-mix(in srgb,var(--hp-gold) 14%,transparent);}
  .method-chip.standard,.method-chip.container{border-color:color-mix(in srgb,var(--hp-gold) 35%,var(--hp-border));}

  /* faq */
  .faq{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;}
  .faq-item{margin:0;background:color-mix(in srgb,var(--hp-surface) 72%,transparent);border:1px solid var(--hp-border);border-radius:12px;overflow:hidden;transition:border-color .2s ease,box-shadow .2s ease;}
  .faq-item:hover{border-color:color-mix(in srgb,var(--hp-gold) 38%,var(--hp-border));}
  .faq-item summary{display:flex;align-items:center;gap:16px;cursor:pointer;list-style:none;padding:15px 16px;font-size:14px;font-weight:700;color:var(--hp-ink);}
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-item summary::before{display:none !important;}   /* kill Starlight's details caret */
  .faq-q{flex:1;text-align:left;}
  .faq-mark{flex:none;width:28px;height:28px;border-radius:999px;display:grid;place-items:center;color:var(--hp-gold);background:color-mix(in srgb,var(--hp-gold) 12%,transparent);transition:transform .25s ease,background .2s ease;}
  .faq-mark svg{width:15px;height:15px;}
  .faq-item[open] .faq-mark{transform:rotate(180deg);background:color-mix(in srgb,var(--hp-gold) 22%,transparent);}
  .faq-item[open]{border-color:color-mix(in srgb,var(--hp-gold) 42%,var(--hp-border));box-shadow:0 14px 30px -22px rgba(15,27,46,.5);}
  .faq-answer{padding:0 20px 18px 20px;}
  .faq-answer p{margin:0;padding-top:14px;border-top:1px solid var(--hp-border);font-size:14.5px;line-height:1.65;color:var(--hp-ink-soft);}

  /* CTA */
  .cta{margin-top:48px;border-radius:22px;padding:clamp(40px,6vw,62px) 40px;background:radial-gradient(110% 130% at 0% 0%,#27406e 0%,transparent 55%),radial-gradient(90% 120% at 100% 100%,color-mix(in srgb,var(--hp-gold) 22%,transparent) 0%,transparent 50%),linear-gradient(150deg,#1b2a44,#0f1726);border:1px solid color-mix(in srgb,var(--hp-gold) 20%,var(--hp-border));text-align:center;}
  .cta-inner{max-width:54ch;margin-inline:auto;}
  .cta-eyebrow{display:inline-block;font-size:12px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--hp-gold-2);margin-bottom:14px;}
  .cta h2{color:#fff;font-size:clamp(24px,3.2vw,34px);letter-spacing:-.025em;font-weight:800;margin-bottom:12px;}
  .cta p{color:#c7d0e2;font-size:16px;margin-bottom:28px;}
  .cta-actions{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;align-items:center;}
  .btn.lg{padding:14px 28px;font-size:16px;}
  .cta .btn.ghost{background:rgba(255,255,255,.08);color:#fff;border-color:rgba(255,255,255,.24);}
  .cta .btn.ghost:hover{border-color:var(--hp-gold-2);background:rgba(255,255,255,.12);}
  .cta .btn.link{background:transparent;border-color:transparent;color:#c7d0e2;padding:14px 8px;gap:6px;}
  .cta .btn.link svg{width:15px;height:15px;}
  .cta .btn.link:hover{color:#fff;transform:none;}

  @media (max-width:880px){
    .faq{grid-template-columns:1fr;}
    .ben-grid,.doc-grid,.role-grid{grid-template-columns:1fr;}
    .ben-card:nth-child(odd),.doc-card:nth-child(odd),.role-card:not(:last-child){border-inline-end:0;}
    .ben-card,.doc-card,.role-card{border-bottom:1px solid var(--hp-border);}
    .ben-card:last-child,.doc-card:last-child,.role-card:last-child{border-bottom:0;}
    .cta{padding:30px 24px;}
  }
  @media (max-width:900px){
    .hr-walk-steps{grid-template-columns:1fr;gap:12px;}
    .hr-walk .hr-walk-steps li{flex-direction:row;align-items:flex-start;gap:11px;}
  }
  @media (max-width:760px){
    .path-grid{grid-template-columns:1fr;}
  }
  @media (max-width:560px){
    .sb-hero{padding-top:34px;gap:28px;}
    .eyebrow{font-size:10.5px;letter-spacing:.1em;padding-inline:11px;}
    .hero-copy h1{font-size:clamp(36px,11vw,48px);}
    .hero-copy p{font-size:16px;line-height:1.55;}
    .hero-cta{display:grid;grid-template-columns:1fr 1fr;width:100%;}
    .hero-cta .btn{padding-inline:10px;font-size:14px;}
    .hero-cta .btn.text{grid-column:1/-1;min-height:36px;}
    .band{border-radius:16px;align-items:flex-start;}
    .secondary-block{padding:18px;}
    .sb-subnav{justify-content:flex-start;}
    .ben-card{padding-inline:8px;}
    .doc-card{padding-inline:8px;}
    .method-strip{justify-content:flex-start;}
    .cta-actions{display:grid;}
  }
  @media (prefers-reduced-motion: reduce){
    .btn,.path-card,.ben-card,.doc-card,.path-cta svg,.doc-arrow,.faq-mark,.sb-subnav a{transition:none;}
  }
</style>

<style is:global>
  /* Splash homepage only: hide Starlight's auto page-title panel -
     Home.astro provides its own hero <h1>. Guarded by :has(.sb-home) so the
     inner guide pages keep their normal page title. */
  main:has(.sb-home) .content-panel:has(> .sl-container > h1#_top){ display:none; }
  /* let the homepage use a touch more width than the default splash gutter */
  .sl-markdown-content:has(.sb-home){ width:100%; }
</style>

<script>
  // Sticky sub-nav: smooth-scroll on click (respecting reduced-motion) and a
  // scroll-spy that marks the section currently in view.
  function initSubnav() {
    const nav = document.querySelector('.sb-subnav');
    if (!nav || nav.dataset.ready) return;
    nav.dataset.ready = '1';
    const links = Array.from(nav.querySelectorAll('a[href^="#"]'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    const byId = new Map();

    links.forEach((a) => {
      const id = a.getAttribute('href').slice(1);
      byId.set(id, a);
      a.addEventListener('click', (e) => {
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: reduce.matches ? 'auto' : 'smooth', block: 'start' });
        history.replaceState(null, '', '#' + id);
      });
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((en) => {
        if (!en.isIntersecting) return;
        links.forEach((l) => l.removeAttribute('aria-current'));
        const a = byId.get(en.target.id);
        if (a) a.setAttribute('aria-current', 'true');
      });
    }, { rootMargin: '-35% 0px -60% 0px', threshold: 0 });

    byId.forEach((_a, id) => {
      const el = document.getElementById(id);
      if (el) io.observe(el);
    });
  }
  initSubnav();
  document.addEventListener('astro:after-swap', initSubnav);
</script>
