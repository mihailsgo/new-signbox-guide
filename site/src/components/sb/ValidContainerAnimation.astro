<style>
  /* Self-contained fixed-look illustration; strip the figure's default margins
     so the wrapper controls its own height. */
  .valid-container { margin: 0; }
  /* The reference build assumes a browser clean slate (border-box, default
     line-height, no element margins). Starlight's global typography leaks in
     otherwise - inflating line-height and adding margins - which makes the
     content overflow the fixed 1360x900 canvas. Re-establish the reference's
     slate, scoped to the frame, so the port matches 1:1. Inline margins in the
     markup still win (higher cascade origin), so only leaked margins are zeroed. */
  .valid-container :global(.svc-wrap),
  .valid-container :global(.svc-frame),
  .valid-container :global(.svc-frame *) { box-sizing: border-box; line-height: normal; margin: 0; }
</style>

<script>
  /* Driver - CSS does all the animating. This only fits the fixed-width design
     frame to its container width (transform: scale) and respects reduced motion.
     zoom/look/pace are hard-coded inline on .svc-frame (Standard / Midnight
     glass / Standard 13s), so there is nothing else to wire. */
  const SVC_REF = 1360; // "Standard" reference width from the handoff.
  const SVC_FRAME_H = 900;

  function initValidContainer() {
    document.querySelectorAll<HTMLElement>('.valid-container').forEach((fig) => {
      const wrap = fig.querySelector<HTMLElement>('.svc-wrap');
      const frame = fig.querySelector<HTMLElement>('.svc-frame');
      if (!wrap || !frame) return;

      const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) frame.style.setProperty('--pstate', 'paused');

      const fitScale = () => {
        frame.style.width = SVC_REF + 'px';
        const scale = (wrap.clientWidth || SVC_REF) / SVC_REF;
        frame.style.transform = 'scale(' + scale + ')';
        wrap.style.height = (SVC_FRAME_H * scale) + 'px';
      };

      // Re-init across view transitions without stacking observers.
      const prev = (fig as any).__svcRO as ResizeObserver | undefined;
      if (prev) prev.disconnect();
      const ro = new ResizeObserver(fitScale);
      ro.observe(wrap);
      (fig as any).__svcRO = ro;

      fitScale();
    });
  }

  initValidContainer();
  document.addEventListener('astro:page-load', initValidContainer);
  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll<HTMLElement>('.valid-container').forEach((fig) => {
      const ro = (fig as any).__svcRO as ResizeObserver | undefined;
      if (ro) { ro.disconnect(); (fig as any).__svcRO = undefined; }
    });
  });
</script>
