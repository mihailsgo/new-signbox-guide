  @keyframes vcCkS { 0%,29%{opacity:0;transform:scale(0)} 32%{opacity:1;transform:scale(1.25)} 35%{transform:scale(1)} 96%{opacity:1} 98%{opacity:0} 100%{opacity:0} }
