---
import '../../styles/signbox-anim.css';

interface Props { class?: string; caption?: string; showCaption?: boolean; }

const {
  class: className = '',
  caption = 'Initiators work in the internal portal; a document is handed off securely, signed externally, and the signed status returns automatically.',
  showCaption = true,
} = Astro.props;
---

<figure class={`sb-anim portal-split ${className}`} role="group" aria-label="Secure handoff from the internal workspace to the external signer">
  <div class="sb-stage pa-stage">
    <div class="pa-flow">
      <!-- Internal zone -->
      <div class="pa-node pa-internal">
        <span class="pa-orb" aria-hidden="true">
          <span class="pa-ic">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="13" rx="2"/><path d="M8 21h8M12 17v4M7 9h6M7 12h4"/>
            </svg>
          </span>
        </span>
        <span class="pa-label">Internal</span>
        <span class="pa-sub">Initiates</span>
      </div>

      <!-- Secure handoff -->
      <div class="pa-link" aria-hidden="true">
        <span class="pa-link-label">Secure handoff</span>
        <span class="pa-line"></span>
        <span class="pa-lock">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>
          </svg>
        </span>
        <span class="pa-token pa-token-out">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h5"/></svg>
        </span>
        <span class="pa-token pa-token-back">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg>
        </span>
        <span class="pa-return">Signed status</span>
      </div>

      <!-- External zone -->
      <div class="pa-node pa-external">
        <span class="pa-orb" aria-hidden="true">
          <span class="pa-ic">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
            </svg>
          </span>
          <span class="pa-badge" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m5 13 4 4L19 7"/></svg>
          </span>
        </span>
        <span class="pa-label">External</span>
        <span class="pa-sub">Signs</span>
      </div>
    </div>
  </div>
  {showCaption && <figcaption class="sb-cap">{caption}</figcaption>}
</figure>

<style>
  .portal-split{margin:0;display:flex;flex-direction:column;gap:14px}
  .pa-stage{padding:clamp(26px,4vw,46px) clamp(18px,3vw,34px)}
  .pa-flow{position:relative;z-index:1;display:grid;grid-template-columns:1fr minmax(120px,1.1fr) 1fr;align-items:center;gap:8px;min-height:200px}

  /* the two zones */
  .pa-node{display:flex;flex-direction:column;align-items:center;gap:12px;text-align:center}
  .pa-orb{position:relative;width:clamp(92px,13vw,124px);height:clamp(92px,13vw,124px);display:grid;place-items:center;border-radius:50%;
    border:1px solid var(--sb-border-strong);background:radial-gradient(circle at 50% 38%,color-mix(in srgb,var(--sb-blue) 16%,var(--sb-card)),var(--sb-card) 72%);
    box-shadow:var(--sb-shadow-sm);transition:box-shadow .5s ease,border-color .5s ease,transform .5s ease}
  .pa-external .pa-orb{background:radial-gradient(circle at 50% 38%,color-mix(in srgb,var(--sb-gold) 16%,var(--sb-card)),var(--sb-card) 72%)}
  .pa-ic{width:46%;height:46%;color:var(--sb-blue);display:grid;place-items:center}
  .pa-external .pa-ic{color:var(--sb-gold)}
  .pa-ic svg{width:100%;height:100%}
  .pa-label{font-size:15px;font-weight:850;letter-spacing:-.01em;color:var(--sb-ink)}
  .pa-sub{font-size:11px;color:var(--sb-muted);margin-top:-6px}
  /* "signed" badge on the external orb */
  .pa-badge{position:absolute;right:2px;bottom:2px;width:30%;height:30%;min-width:24px;min-height:24px;display:grid;place-items:center;border-radius:50%;
    background:var(--sb-success);color:#fff;box-shadow:0 4px 12px -4px color-mix(in srgb,var(--sb-success) 60%,transparent);
    opacity:0;transform:scale(.5);transition:opacity .4s ease,transform .4s cubic-bezier(.22,1,.36,1)}
  .pa-badge svg{width:58%;height:58%}

  /* the secure-handoff link */
  .pa-link{position:relative;height:64px;display:flex;align-items:center;justify-content:center}
  .pa-line{position:absolute;left:0;right:0;top:50%;height:2px;transform:translateY(-50%);
    background:repeating-linear-gradient(90deg,var(--sb-border-strong) 0 6px,transparent 6px 12px)}
  .pa-lock{position:relative;z-index:2;width:36px;height:36px;display:grid;place-items:center;border-radius:11px;
    border:1px solid var(--sb-border-strong);background:var(--sb-card);color:var(--sb-ink-soft);box-shadow:var(--sb-shadow-sm)}
  .pa-lock svg{width:17px;height:17px}
  .pa-link-label{position:absolute;top:-2px;left:50%;transform:translateX(-50%);white-space:nowrap;font-size:9.5px;font-weight:800;letter-spacing:.05em;color:var(--sb-gold)}
  .pa-return{position:absolute;bottom:-2px;left:50%;transform:translateX(-50%);white-space:nowrap;font-size:9.5px;font-weight:800;letter-spacing:.05em;color:var(--sb-success)}
  .pa-token{position:absolute;z-index:3;top:50%;left:6%;width:26px;height:26px;margin-top:-13px;display:grid;place-items:center;border-radius:8px;opacity:0}
  .pa-token svg{width:14px;height:14px}
  .pa-token-out{color:#241a07;background:var(--sb-gold);box-shadow:0 0 14px var(--sb-glow-gold)}
  .pa-token-back{color:#fff;background:var(--sb-success);box-shadow:0 0 14px color-mix(in srgb,var(--sb-success) 45%,transparent)}

  @media (prefers-reduced-motion:no-preference){
    :global(.is-animating).portal-split .pa-internal .pa-orb{animation:paInternal 8s cubic-bezier(.22,1,.36,1) infinite}
    :global(.is-animating).portal-split .pa-external .pa-orb{animation:paExternal 8s cubic-bezier(.22,1,.36,1) infinite}
    :global(.is-animating).portal-split .pa-badge{animation:paBadge 8s cubic-bezier(.22,1,.36,1) infinite}
    :global(.is-animating).portal-split .pa-token-out{animation:paTokenOut 8s cubic-bezier(.45,0,.55,1) infinite}
    :global(.is-animating).portal-split .pa-token-back{animation:paTokenBack 8s cubic-bezier(.45,0,.55,1) infinite}
    :global(.is-animating).portal-split .pa-lock{animation:paLock 8s ease infinite}
  }
  /* reduced-motion: show the resolved (signed) end state */
  @media (prefers-reduced-motion:reduce){ .pa-badge{opacity:1;transform:scale(1)} }

  @keyframes paInternal{0%,16%{box-shadow:0 0 0 4px color-mix(in srgb,var(--sb-blue) 20%,transparent),var(--sb-shadow-sm);border-color:var(--sb-blue)}26%,100%{box-shadow:var(--sb-shadow-sm)}}
  @keyframes paExternal{0%,40%{box-shadow:var(--sb-shadow-sm)}50%,72%{box-shadow:0 0 0 4px color-mix(in srgb,var(--sb-gold) 22%,transparent),var(--sb-shadow-sm);border-color:var(--sb-gold);transform:translateY(-2px)}82%,100%{box-shadow:var(--sb-shadow-sm);transform:none}}
  @keyframes paBadge{0%,46%{opacity:0;transform:scale(.5)}54%,100%{opacity:1;transform:scale(1)}}
  @keyframes paLock{0%,18%{color:var(--sb-ink-soft)}24%,58%{color:var(--sb-gold)}66%,100%{color:var(--sb-ink-soft)}}
  @keyframes paTokenOut{0%,18%{opacity:0;left:6%}22%{opacity:1}40%{opacity:1;left:calc(94% - 26px)}44%,100%{opacity:0;left:calc(94% - 26px)}}
  @keyframes paTokenBack{0%,58%{opacity:0;left:calc(94% - 26px)}62%{opacity:1}80%{opacity:1;left:6%}84%,100%{opacity:0;left:6%}}

  @media (max-width:680px){
    .pa-flow{grid-template-columns:1fr;gap:4px;min-height:0}
    .pa-link{height:90px;width:64px;margin-inline:auto}
    .pa-line{left:50%;right:auto;top:6px;bottom:6px;height:auto;width:2px;transform:translateX(-50%);
      background:repeating-linear-gradient(180deg,var(--sb-border-strong) 0 6px,transparent 6px 12px)}
    .pa-link-label{top:50%;left:auto;right:calc(50% + 26px);transform:translateY(-50%);text-align:right}
    .pa-return{bottom:auto;top:50%;left:calc(50% + 26px);transform:translateY(-50%)}
    .pa-token{left:50%;top:6px;margin:0 0 0 -13px}
    @keyframes paTokenOut{0%,18%{opacity:0;top:6px}22%{opacity:1}40%{opacity:1;top:calc(100% - 32px)}44%,100%{opacity:0;top:calc(100% - 32px)}}
    @keyframes paTokenBack{0%,58%{opacity:0;top:calc(100% - 32px)}62%{opacity:1}80%{opacity:1;top:6px}84%,100%{opacity:0;top:6px}}
  }
</style>

<script>
  function initPortalSplitAnimations() {
    document.querySelectorAll('.portal-split').forEach((element) => {
      if (element.hasAttribute('data-observed')) return;
      element.setAttribute('data-observed', 'true');
      const observer = new IntersectionObserver(([entry]) => element.classList.toggle('is-animating', entry.isIntersecting), { threshold: 0.2 });
      observer.observe(element);
    });
  }
  initPortalSplitAnimations();
  document.addEventListener('astro:after-swap', initPortalSplitAnimations);
</script>
