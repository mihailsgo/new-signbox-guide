---
import Default from '@astrojs/starlight/components/Head.astro';
import { ClientRouter } from 'astro:transitions';
---
<Default><slot /></Default>
<ClientRouter />

<!-- Fonts for the homepage hero animation (SignBoxHero): Manrope (body),
     Space Grotesk (titles), Space Mono (technical chips). -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&family=Space+Mono:wght@400;700&display=swap"
  rel="stylesheet"
/>

<script>
  import mediumZoom from 'medium-zoom';

  const ZOOM_OPTS = { background: 'rgba(6, 10, 22, 0.94)', margin: 28 };

  // keep a single zoom instance across view transitions
  let zoom: any = null;

  function buildZoom() {
    zoom = mediumZoom('.sl-markdown-content img', ZOOM_OPTS);
    (window as any).__zoom = zoom;
  }

  // Guaranteed close. medium-zoom's animated close waits for a `transitionend`
  // on the image; when the image has no transform transition (reduced motion,
  // or right after a view transition) that event never fires and the overlay
  // gets stuck open - the close button, image click, overlay click and Esc all
  // appeared to "do nothing". So we ask medium-zoom to close, then hard-strip
  // the DOM if it's still open and re-arm a fresh instance for the next click.
  function hardCloseZoom() {
    if (zoom) { try { zoom.close(); } catch {} }
    setTimeout(() => {
      const stuck =
        document.querySelector('.medium-zoom-overlay') ||
        document.querySelector('.medium-zoom-image--opened');
      if (!stuck) return; // animated close already finished cleanly
      document.querySelectorAll('.medium-zoom-overlay').forEach((o) => o.remove());
      document.querySelectorAll('.medium-zoom-image--opened').forEach((i) => {
        i.classList.remove('medium-zoom-image--opened');
        (i as HTMLElement).style.transform = '';
        (i as HTMLElement).style.transition = '';
        (i as HTMLElement).style.willChange = '';
      });
      document.body.classList.remove('tl-zoom-open');
      if (zoom) { try { zoom.detach(); } catch {} }
      buildZoom();
    }, 320);
  }

  function enhance() {
    const content = document.querySelector('.sl-markdown-content');

    // 1) Click-to-zoom lightbox on screenshots
    if (zoom) {
      try { zoom.detach(); } catch {}
    }
    buildZoom();

    // close button + hint (medium-zoom has none by default)
    if (!document.getElementById('tl-zoom-close')) {
      const btn = document.createElement('button');
      btn.id = 'tl-zoom-close';
      btn.className = 'tl-zoom-close';
      btn.setAttribute('aria-label', 'Close enlarged image');
      btn.innerHTML =
        '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg><span>Close</span>';
      btn.addEventListener('click', hardCloseZoom);
      document.body.appendChild(btn);
      const hint = document.createElement('div');
      hint.id = 'tl-zoom-hint';
      hint.className = 'tl-zoom-hint';
      hint.textContent = 'Click anywhere or press Esc to close';
      document.body.appendChild(hint);
    }

    // Global, instance-independent close triggers (set up once): Esc and a click
    // on the overlay or the enlarged image always force the lightbox shut.
    if (!(window as any).__sbZoomClose) {
      (window as any).__sbZoomClose = true;
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && document.querySelector('.medium-zoom-overlay')) hardCloseZoom();
      });
      document.addEventListener(
        'click',
        (e) => {
          const t = e.target as Element | null;
          if (t && t.classList && (t.classList.contains('medium-zoom-overlay') || t.classList.contains('medium-zoom-image--opened'))) {
            hardCloseZoom();
          }
        },
        true
      );
    }

    // Reflect the open/closed state on <body> from medium-zoom's OWN marker
    // class, set up exactly once. The zoom instance is rebuilt on every view
    // transition; per-instance `.on('opened')` handlers proved unreliable after
    // a client-side (ClientRouter) navigation, leaving the image enlarged but
    // the Close button + hint hidden ("just a bigger image, no zoom-out UI").
    // Observing the DOM marker instead is instance-independent and bulletproof.
    if (!(window as any).__sbZoomObserver) {
      const syncZoomState = () =>
        document.body.classList.toggle(
          'tl-zoom-open',
          !!document.querySelector('.medium-zoom-image--opened')
        );
      const mo = new MutationObserver(syncZoomState);
      // Observe <html>, not <body>: Astro's ClientRouter REPLACES the <body>
      // element on every navigation, which would orphan a body-bound observer.
      // <html> persists, so a single subtree observer keeps working forever.
      mo.observe(document.documentElement, {
        subtree: true,
        attributes: true,
        attributeFilter: ['class'],
      });
      (window as any).__sbZoomObserver = mo;
      syncZoomState();
    }

    // 2) Scroll-reveal - media only (screenshots / figures). Reading content
    //    (headings, text, tables, lists) renders instantly to avoid "pop-in".
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (content) {
      const targets = content.querySelectorAll('p > img, figure, img');
      if (reduce || !('IntersectionObserver' in window)) {
        targets.forEach((t) => t.classList.add('reveal', 'revealed'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('revealed');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -6% 0px', threshold: 0.05 }
        );
        targets.forEach((t) => {
          t.classList.add('reveal');
          io.observe(t);
        });
      }
    }

    // 3) Reading-progress bar
    let bar = document.getElementById('reading-progress');
    if (!bar) {
      bar = document.createElement('div');
      bar.id = 'reading-progress';
      document.body.appendChild(bar);
    }
    const onScroll = () => {
      const h = document.documentElement;
      const max = h.scrollHeight - h.clientHeight;
      const p = max > 0 ? (h.scrollTop / max) * 100 : 0;
      bar!.style.width = p + '%';
    };
    // Replace the previous handler (a fresh closure each navigation) so scroll
    // listeners don't accumulate across view transitions.
    if ((window as any).__sbScroll) {
      window.removeEventListener('scroll', (window as any).__sbScroll);
    }
    (window as any).__sbScroll = onScroll;
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Tear medium-zoom down BEFORE Astro's ClientRouter swaps <body>, while the
  // current images still exist. Detaching AFTER the swap (the old default) left
  // a stale instance bound to removed nodes; after a client-side navigation it
  // would still open an image but could no longer close it (close button, image
  // click, overlay click and Esc all no-opped). Clean teardown here guarantees
  // exactly one live, fully-closable instance per page.
  function teardownZoom() {
    if (zoom) { try { zoom.close(); } catch {} try { zoom.detach(); } catch {} zoom = null; }
    document.querySelectorAll('.medium-zoom-overlay').forEach((o) => o.remove());
    document
      .querySelectorAll('.medium-zoom-image--opened')
      .forEach((i) => i.classList.remove('medium-zoom-image--opened'));
    document.body.classList.remove('tl-zoom-open');
    (window as any).__zoom = null;
  }
  document.addEventListener('astro:before-swap', teardownZoom);
  document.addEventListener('astro:page-load', enhance);
</script>
